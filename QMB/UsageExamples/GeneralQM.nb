Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"1.", " ", "Construct", " ", "the", " ", "Bell", " ", "state"}], 
    " ", "|", 
    RowBox[{"\[Phi]", "+", "\\>"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bellState", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}], " ",
       "/", " ", 
      RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rhoBell", " ", "=", " ", 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", " ", "bellState", ",", " ", 
       RowBox[{"Conjugate", "[", "bellState", "]"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Apply", " ", "Partial", " ", "Transpose", " ", "over", " ", 
     "subsystem", " ", "2"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rhoPT", " ", "=", " ", 
     RowBox[{"PartialTranspose", "[", 
      RowBox[{"rhoBell", ",", " ", "2"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"3.", " ", "Check", " ", "for", " ", "entanglement", " ", 
     RowBox[{"(", 
      RowBox[{"Peres", "-", 
       RowBox[{"Horodecki", " ", "criterion"}]}], ")"}]}], " ", "*)"}], "\n", 
   
   RowBox[{"eigenvalues", " ", "=", " ", 
    RowBox[{"Eigenvalues", "[", "rhoPT", "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Output", ":", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "2"}], ",", " ", 
        RowBox[{"1", "/", "2"}], ",", " ", 
        RowBox[{"1", "/", "2"}], ",", " ", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "2"}]}], "}"}]}], " ", "->", " ", 
     RowBox[{
     "The", " ", "negative", " ", "eigenvalue", " ", "confirms", " ", 
      "entanglement"}]}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9829463820912333`*^9, 3.982946383061735*^9}},
 CellLabel->
  "In[192]:=",ExpressionUUID->"23361ee0-6b64-4e73-8229-ce6816b6a4f7"],

