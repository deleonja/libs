      "RecoveredVarTheta", ",", " ", "RecoveredPhi", ",", " ", 
       "RecoveredThetaR"}], "}"}], " ", "=", " ", 
     RowBox[{"SU2RotationParameters", "[", "TestMatrix", "]"}]}], ";"}], 
