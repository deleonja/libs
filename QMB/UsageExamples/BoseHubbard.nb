Cell[BoxData[{
 RowBox[{
  RowBox[{"tH", "=", 
   RowBox[{"2", " ", "Pi"}]}], ";", 
  RowBox[{"f", "=", 
   RowBox[{"1", "/", "100"}]}], ";", 
  RowBox[{"rate", "=", "20."}], ";", 
  RowBox[{"tmax", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"times", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"f", ",", "tmax", ",", 
     RowBox[{"f", "/", "rate"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SFFDat", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"data", "=", 
       RowBox[{
        RowBox[{"Unfold", "[", "UnitaryData", "]"}], 
        "[", "\"\<UnfoldedLevels\>\"", "]"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"#", ",", 
         RowBox[{"SFF", "[", 
          RowBox[{"data", ",", 
           RowBox[{"tH", " ", "#"}]}], "]"}]}], "}"}], "&"}], "/@", 
      "times"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bin", "=", "75"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SmoothSFFDat", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"tim", "=", 
        RowBox[{"MovingAverage", "[", 
         RowBox[{
          RowBox[{"First", "/@", "SFFDat"}], ",", "bin"}], "]"}]}], ",", 
       RowBox[{"dat", "=", 
        RowBox[{"MovingAverage", "[", 
         RowBox[{
          RowBox[{"Last", "/@", "SFFDat"}], ",", "bin"}], "]"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tim", "[", 
          RowBox[{"[", "#", "]"}], "]"}], ",", 
         RowBox[{"dat", "[", 
          RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"tim", "//", "Length"}], "]"}]}]}], "]"}]}], ";"}]}], "Input",E\
xpressionUUID->"967a67ec-277b-4bb9-80ed-e47f7f995cc4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"GOESFF", "[", "t_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"t", "<", "1"}], ",", 
     RowBox[{
      RowBox[{"2", "t"}], "-", 
      RowBox[{"t", "*", 
       RowBox[{"Log", "[", 
        RowBox[{"1", "+", 
         RowBox[{"2", "*", "t"}]}], "]"}]}]}], ",", 
     RowBox[{"2", "-", 
      RowBox[{"t", "*", 
       RowBox[{"Log", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "t"}], "+", "1"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "t"}], "-", "1"}], ")"}]}], "]"}]}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"3135452e-19e2-4124-a7d7-d217dbd8326b"]
}, Closed]]
}, Open  ]]
