204118e4c820"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"tH", "=", 
       RowBox[{"2", "Pi"}]}], ",", 
      RowBox[{"f", "=", 
       RowBox[{"1", "/", "100"}]}], ",", 
      RowBox[{"rate", "=", "20"}], ",", 
      RowBox[{"tmax", "=", "3"}], ",", 
      RowBox[{"bin", "=", "75"}], ",", 
      RowBox[{"hamiltonian", "=", 
       RowBox[{"PeriodicBoseHubbard", "[", 
        RowBox[{"7", ",", "7", ",", "2", ",", "1"}], "]"}]}], ",", "times", ",",
       "SFFDat", ",", "SmoothSFFDat"}], "}"}], ",", 
    RowBox[{
     RowBox[{"times", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"f", ",", "tmax", ",", 
        RowBox[{"f", "/", "rate"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SFFDat", "=", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"data", "=", 
          RowBox[{
           RowBox[{"Unfold", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"hamiltonian", "//", "Normal"}], "//", "Eigenvalues"}], 
             "//", "Sort"}], "]"}], "[", "\"\<UnfoldedLevels\>\"", "]"}]}], 
         "}"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"#", ",", 
            RowBox[{"SpectralFormFactor", "[", 
             RowBox[{"data", ",", 
              RowBox[{"tH", " ", "#"}]}], "]"}]}], "}"}], "&"}], "/@", 
         "times"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bin", "=", "75"}], ";", "\[IndentingNewLine]", 
     RowBox[{"SmoothSFFDat", "=", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"tim", "=", 
           RowBox[{"MovingAverage", "[", 
            RowBox[{
             RowBox[{"First", "/@", "SFFDat"}], ",", "bin"}], "]"}]}], ",", 
          RowBox[{"dat", "=", 
           RowBox[{"MovingAverage", "[", 
            RowBox[{
             RowBox[{"Last", "/@", "SFFDat"}], ",", "bin"}], "]"}]}]}], "}"}],
         ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"tim", "[", 
             RowBox[{"[", "#", "]"}], "]"}], ",", 
            RowBox[{"dat", "[", 
             RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         RowBox[{"Range", "[", 
          RowBox[{"tim", "//", "Length"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{"{", 
       RowBox[{"ListPlot", "[", 
        RowBox[{"SmoothSFFDat", ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"{", "Red", "}"}]}], ",", 
         RowBox[{"ImageSize", "->", "Large"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\< \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"t\", \"TI\"], \"\[CenterDot]\", 
SubscriptBox[
StyleBox[\"t\", \"TI\"], 
StyleBox[\"H\", \"TI\"]]}], TraditionalForm], \"errors\" -> {}, \"input\" -> \
\"t\\\\cdot t_H\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", 
            ",", " ", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"S\", \"TI\"], 
StyleBox[\"F\", \"TI\"], 
StyleBox[\"F\", \"TI\"]}], TraditionalForm], \"errors\" -> {}, \"input\" -> \
\"SFF\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\""}], "}"}]}],
          ",", 
         RowBox[{"AxesStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Black", ",", " ", "22"}], "]"}]}]}], "]"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
