  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "\!\(\*StyleBox[RowBox[{\"SYKHamiltonian\", \"[\", StyleBox[\"\
\[ScriptCapitalN]\", \"TI\"], \",\", StyleBox[\"J\", \"TI\"], \"]\"}], \
\"MR\"]\) yields the Hamiltonian of the q=4 Sachdev-Ye-Kitaev (SYK) model for \
\!\(\*StyleBox[\"\[ScriptCapitalN]\", \"TI\"]\) Majorana fermions and \
coupling variance J. \n\!\(\*StyleBox[\"SYKHamiltonian\", \"MR\"]\) \
\!\(\*StyleBox[\"Options\", \"MR\"]\): ParitySector.", "Documentation" -> 
    None, "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QMB`ManyBody`SYKHamiltonian, {QMB`ManyBody`SYKHamiltonian[
         Pattern[QMB`ManyBody`Fermions`Private`NumMajoranas, 
          Blank[Integer]], 
         PatternTest[
          Pattern[QMB`ManyBody`Fermions`Private`CouplingJ, 
           Blank[]], NumericQ], 
         OptionsPattern[]] :> 
       Module[{QMB`ManyBody`Fermions`Private`Parity, 
          QMB`ManyBody`Fermions`Private`NumSpins, 
          QMB`ManyBody`Fermions`Private`BasisTerms, 
          QMB`ManyBody`Fermions`Private`Sigma, 
          QMB`ManyBody`Fermions`Private`Couplings, 
          QMB`ManyBody`Fermions`Private`FullHamiltonian}, 
         QMB`ManyBody`Fermions`Private`Parity = 
          OptionValue[QMB`ManyBody`ParitySector]; 
         QMB`ManyBody`Fermions`Private`NumSpins = 
          QMB`ManyBody`Fermions`Private`NumMajoranas/2; If[
           Not[
            IntegerQ[QMB`ManyBody`Fermions`Private`NumSpins]], Message[
             MessageName[QMB`ManyBody`SYKHamiltonian, "evenN"]]; 
           Return[$Failed]]; 
         QMB`ManyBody`Fermions`Private`t1 = AbsoluteTime[]; 
         QMB`ManyBody`Fermions`Private`BasisTerms = 
          QMB`ManyBody`Fermions`Private`FourBodyBasisTerms[
           QMB`ManyBody`Fermions`Private`NumMajoranas]; 
         QMB`ManyBody`Fermions`Private`t2 = AbsoluteTime[]; 
         Print[QMB`ManyBody`Fermions`Private`t2 - 
           QMB`ManyBody`Fermions`Private`t1]; 
         QMB`ManyBody`Fermions`Private`Sigma = 
          QMB`ManyBody`Fermions`Private`CouplingJ 
           Sqrt[6./QMB`ManyBody`Fermions`Private`NumMajoranas^3]; 
         QMB`ManyBody`Fermions`Private`Couplings = RandomVariate[
            NormalDistribution[0, QMB`ManyBody`Fermions`Private`Sigma], 
            Length[QMB`ManyBody`Fermions`Private`BasisTerms]]; 
         QMB`ManyBody`Fermions`Private`t3 = AbsoluteTime[]; 
         Print[QMB`ManyBody`Fermions`Private`t3 - 
           QMB`ManyBody`Fermions`Private`t2]; 
         QMB`ManyBody`Fermions`Private`FullHamiltonian = Chop[
            Total[
            QMB`ManyBody`Fermions`Private`Couplings 
             QMB`ManyBody`Fermions`Private`BasisTerms]]; 
         QMB`ManyBody`Fermions`Private`t4 = AbsoluteTime[]; 
         Print[QMB`ManyBody`Fermions`Private`t4 - 
           QMB`ManyBody`Fermions`Private`t3]; 
         If[QMB`ManyBody`Fermions`Private`Parity === "None", 
           Return[QMB`ManyBody`Fermions`Private`FullHamiltonian]]; (Part[
          QMB`ManyBody`Fermions`Private`FullHamiltonian, #, #]& )[
           QMB`ManyBody`Fermions`Private`GetParitySectorIndices[
           QMB`ManyBody`Fermions`Private`NumSpins, 
            QMB`ManyBody`Fermions`Private`Parity]]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {QMB`ManyBody`ParitySector -> "None"}, "Attributes" -> {}, 
    "FullName" -> "QMB`ManyBody`SYKHamiltonian"|>, False]]], "Output",
