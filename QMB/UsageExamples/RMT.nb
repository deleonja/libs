Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "1.", " ", "Visualizaci\[OAcute]n", " ", "de", " ", "la", " ", 
    "transici\[OAcute]n", " ", "del", " ", "Caos", " ", "Cu\[AAcute]ntico"}], 
   " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Compara", " ", "sistemas", " ", "integrables", " ", 
    RowBox[{"(", "Poisson", ")"}], " ", "con", " ", "repulsi\[OAcute]n", " ", 
    "de", " ", "niveles", " ", 
    RowBox[{"(", 
     RowBox[{"Wigner", "-", "Dyson"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", "\n", "    ", 
      RowBox[{
       RowBox[{"LevelSpacingDistribution", "[", 
        RowBox[{"s", ",", " ", "0"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{"LevelSpacingDistribution", "[", 
        RowBox[{"s", ",", " ", "1"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{"LevelSpacingDistribution", "[", 
        RowBox[{"s", ",", " ", "2"}], "]"}], ",", "\n", "    ", 
       RowBox[{"LevelSpacingDistribution", "[", 
        RowBox[{"s", ",", " ", "4"}], "]"}]}], "\n", "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"s", ",", " ", "0", ",", " ", "4"}], "}"}], ",", "\n", "    ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Poisson (\[Beta]=0)\>\"", ",", 
        " ", "\"\<GOE (\[Beta]=1)\>\"", ",", " ", "\"\<GUE (\[Beta]=2)\>\"", ",",
         " ", "\"\<GSE (\[Beta]=4)\>\""}], "}"}]}], ",", "\n", "    ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"Black", ",", " ", "Blue", ",", " ", "Red", ",", " ", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", "\n", "    ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<s\>\"", ",", " ", "\"\<P(s)\>\""}], "}"}]}], ",", "\n", 
     "    ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", "\n", "    ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Level Spacing Distributions (Wigner Surmise)\>\""}]}], "\n", 
    "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"2.", " ", "Verificaci\[OAcute]n", " ", "Anal\[IAcute]tica", " ", 
      RowBox[{"Estricta", ":", " ", 
       RowBox[{"Normalizaci\[OAcute]n", " ", "de", " ", 
        RowBox[{"Probabilidad", " ", "\\", "int"}], " ", "P", 
        RowBox[{"(", "s", ")"}], " ", "ds"}]}]}], " ", "=", " ", "1"}], " ", 
    "*)"}], "\n", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"LevelSpacingDistribution", "[", 
      RowBox[{"s", ",", " ", "1"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"s", ",", " ", "0", ",", " ", "Infinity"}], "}"}]}], "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"3.", " ", "Verificaci\[OAcute]n", " ", "Anal\[IAcute]tica", " ", 
      RowBox[{"Estricta", ":", " ", 
       RowBox[{"Normalizaci\[OAcute]n", " ", "de", " ", "la", " ", 
        RowBox[{"media", " ", "\\", "int"}], " ", "s", " ", "P", 
        RowBox[{"(", "s", ")"}], " ", "ds"}]}]}], " ", "=", " ", "1"}], " ", 
    "*)"}], "\n", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"s", " ", "*", " ", 
      RowBox[{"LevelSpacingDistribution", "[", 
       RowBox[{"s", ",", " ", "2"}], "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"s", ",", " ", "0", ",", " ", "Infinity"}], "}"}]}], "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "4.", " ", "Aplicaci\[OAcute]n", " ", "usando", " ", 
     "EmpiricalKLDivergence", " ", "ya", " ", "existente", " ", "en", " ", 
     "tu", " ", "paquete", " ", "QMB"}], " ", "*)"}], "\n", 
   RowBox[{"(*", "\n", "  ", 
    RowBox[{
     RowBox[{"UnfoldedSpacings", " ", "=", " ", 
      RowBox[{"Differences", "[", 
       RowBox[{
        RowBox[{"Unfold", "[", "NumericalSpectrum", "]"}], 
        "[", "\"\<UnfoldedLevels\>\"", "]"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"KLDistanceToGOE", " ", "=", " ", 
      RowBox[{"EmpiricalKLDivergence", "[", 
       RowBox[{"UnfoldedSpacings", ",", " ", 
        RowBox[{
         RowBox[{"LevelSpacingDistribution", "[", 
          RowBox[{"#", ",", " ", "1"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
    "*)"}]}]}]], "Input",
