Cell[BoxData[{
 RowBox[{
  RowBox[{"RepresentativesOddBasis", "[", "basis_", "]"}], ":=", 
  RowBox[{"DeleteDuplicatesBy", "[", 
   RowBox[{
    RowBox[{"Discard", "[", 
     RowBox[{"basis", ",", "PalindromeQ"}], "]"}], ",", 
    RowBox[{
     RowBox[{"Sort", "[", 
      RowBox[{"{", 
       RowBox[{"#", ",", 
        RowBox[{"Reverse", "[", "#", "]"}]}], "}"}], "]"}], "&"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RepresentativesEvenBasis", "[", "basis_", "]"}], ":=", 
  RowBox[{"DeleteDuplicatesBy", "[", 
   RowBox[{"basis", ",", 
    RowBox[{
     RowBox[{"Sort", "[", 
      RowBox[{"{", 
       RowBox[{"#", ",", 
        RowBox[{"Reverse", "[", "#", "]"}]}], "}"}], "]"}], "&"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.960486396353746*^9, 3.960486456376482*^9}},
 CellLabel->
  "In[101]:=",ExpressionUUID->"29f13b6e-394e-4e67-bd94-3c2f6c22afac"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"L", "=", "6"}], ";", 
  RowBox[{"hx", "=", 
   RowBox[{"hz", "=", 
    RowBox[{"J", "=", "1."}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"basis", "=", 
   RowBox[{"Tuples", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "L"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{"IsingHamiltonian", "[", 
    RowBox[{"hx", ",", "hz", ",", "J", ",", "L"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rules", "=", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{"basis", "->", 
     RowBox[{"Range", "[", 
      RowBox[{"Length", "[", "basis", "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"reps", "=", 
   RowBox[{"Comap", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"RepresentativesEvenBasis", ",", "RepresentativesOddBasis"}], 
      "}"}], ",", "basis"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Heven", "=", 
  RowBox[{
   RowBox[{"1", "/", "2"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#1", ",", "#1"}], "]"}], "]"}], " ", "+", " ", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#1", ",", "#2"}], "]"}], "]"}], "+", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#2", ",", "#1"}], "]"}], "]"}], " ", "+", " ", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#2", ",", "#2"}], "]"}], "]"}]}], " ", "&"}], " ", "@@", 
     " ", 
     RowBox[{"Map", "[", 
      RowBox[{"rules", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Reverse", "/@", "#"}]}], "}"}], "&"}], "[", 
        RowBox[{"reps", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", " ", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Hodd", "=", 
  RowBox[{
   RowBox[{"1", "/", "2"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#1", ",", "#1"}], "]"}], "]"}], " ", "-", " ", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#1", ",", "#2"}], "]"}], "]"}], " ", "-", " ", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#2", ",", "#1"}], "]"}], "]"}], " ", "+", " ", 
       RowBox[{"H", "[", 
        RowBox[{"[", 
         RowBox[{"#2", ",", "#2"}], "]"}], "]"}]}], " ", "&"}], " ", "@@", 
     " ", 
     RowBox[{"Map", "[", 
      RowBox[{"rules", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Reverse", "/@", "#"}]}], "}"}], "&"}], "[", 
        RowBox[{"reps", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", " ", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"#", ".", "Heven", ".", "#"}], "&"}], "[", 
  RowBox[{"DiagonalMatrix", "[", 
   RowBox[{
    RowBox[{"ReplacePart", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"1.", ",", 
        RowBox[{"Length", "[", 
         RowBox[{"reps", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"Thread", "[", 
       RowBox[{
        RowBox[{"Catenate", "[", 
         RowBox[{"Position", "[", 
          RowBox[{
           RowBox[{"reps", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"_", "?", "PalindromeQ"}], ",", "1"}], "]"}], "]"}], "->", 
        
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", "2.", "]"}]}]}], "]"}]}], "]"}], ",", 
    RowBox[{"TargetStructure", "->", "\"\<Sparse\>\""}]}], "]"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.96048651533178*^9, 3.960486707134096*^9}, {
   3.960486746999226*^9, 3.960486895564769*^9}, 3.960487145256769*^9, {
