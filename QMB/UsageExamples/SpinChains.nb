\"}]]\) \!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", RowBox[{\"i\", \"+\", \
\"1\"}]], RowBox[{\"z\"}]]\)) + 1/2 \
\!\(\*SuperscriptBox[SubscriptBox[\"\[Sum]\", RowBox[{\"i\", \"=\", \"1\"}]], \
RowBox[{\"L\"}]]\) \!\(\*StyleBox[RowBox[{SubscriptBox[\"h\", \
RowBox[{\"i\"}]]}], \"TI\"]\) \!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", \
RowBox[{\"i\"}]], RowBox[{\"z\"}]]\).\n\
\!\(\*StyleBox[\"HeisenbergXXXwNoise\", \"MR\"]\) \!\(\*StyleBox[\"Options\", \
\"MR\"]\): BoundaryConditions andMagnonSector.\n\
\!\(\*StyleBox[\"HeisenbergXXXwNoise\", \"MR\"]\) More details in \
arxiv:2512.11030 [Eq. (10)].", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QMB`ManyBody`HeisenbergXXXwNoise, {
      QMB`ManyBody`HeisenbergXXXwNoise[
         Pattern[QMB`ManyBody`SpinChains`Private`FieldList, 
          Blank[List]], 
         Pattern[QMB`ManyBody`SpinChains`Private`NumSites, 
          Blank[Integer]], 
         Pattern[QMB`ManyBody`SpinChains`Private`Opts, 
          OptionsPattern[]]] :> 
       Module[{QMB`ManyBody`SpinChains`Private`OptMagnonSector, 
          QMB`ManyBody`SpinChains`Private`BoundCond, 
          QMB`ManyBody`SpinChains`Private`FullHamiltonian, 
          QMB`ManyBody`SpinChains`Private`SectorIndices}, 
         QMB`ManyBody`SpinChains`Private`OptMagnonSector = 
          OptionValue[QMB`ManyBody`MagnonSector]; 
         QMB`ManyBody`SpinChains`Private`BoundCond = 
          OptionValue[QMB`ManyBody`BoundaryConditions]; If[
           Not[
            QMB`ManyBody`SpinChains`Private`ValidateHamiltonianOptions[
            QMB`ManyBody`SpinChains`Private`NumSites, 
             QMB`ManyBody`SpinChains`Private`BoundCond, "All", "None", 
             QMB`ManyBody`SpinChains`Private`OptMagnonSector]], 
           Return[$Failed]]; 
         QMB`ManyBody`SpinChains`Private`FullHamiltonian = (1./4) (
             QMB`ManyBody`SpinChains`Private`TwoSiteSum[
              1, QMB`ManyBody`SpinChains`Private`BoundCond, 
               QMB`ManyBody`SpinChains`Private`NumSites] + 
             QMB`ManyBody`SpinChains`Private`TwoSiteSum[
              2, QMB`ManyBody`SpinChains`Private`BoundCond, 
               QMB`ManyBody`SpinChains`Private`NumSites] + 
             QMB`ManyBody`SpinChains`Private`TwoSiteSum[
              3, QMB`ManyBody`SpinChains`Private`BoundCond, 
               QMB`ManyBody`SpinChains`Private`NumSites]) + (1./2) 
            QMB`ManyBody`SpinChains`Private`OneSiteSum[
             QMB`ManyBody`SpinChains`Private`FieldList, 3]; 
         If[QMB`ManyBody`SpinChains`Private`OptMagnonSector === "All", 
           Return[QMB`ManyBody`SpinChains`Private`FullHamiltonian]]; 
         QMB`ManyBody`SpinChains`Private`SectorIndices = 
          QMB`ManyBody`SpinChains`Private`MagnonSectorIndices[
           QMB`ManyBody`SpinChains`Private`NumSites, 
            QMB`ManyBody`SpinChains`Private`OptMagnonSector]; 
         Part[QMB`ManyBody`SpinChains`Private`FullHamiltonian, 
           QMB`ManyBody`SpinChains`Private`SectorIndices, 
           QMB`ManyBody`SpinChains`Private`SectorIndices]]}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     QMB`ManyBody`MagnonSector -> "All", QMB`ManyBody`BoundaryConditions -> 
      "Open"}, "Attributes" -> {}, "FullName" -> 
    "QMB`ManyBody`HeisenbergXXXwNoise"|>, False]]], "Output",
