\) (\!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", RowBox[{\"i\"}]], \
RowBox[{\"x\"}]]\) \!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", \
