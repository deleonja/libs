         QMB`ManyBody`SpinChains`Private`DefectField = Normal[
            
            SparseArray[{
             QMB`ManyBody`SpinChains`Private`DSite -> 
              QMB`ManyBody`SpinChains`Private`EpsD}, 
             QMB`ManyBody`SpinChains`Private`NumSites]]; 
         QMB`ManyBody`SpinChains`Private`HamFull = (1./4) 
            QMB`ManyBody`SpinChains`Private`Jxy 
            QMB`ManyBody`SpinChains`Private`TwoSiteSum[
