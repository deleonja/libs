  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "\!\(\*StyleBox[RowBox[{\"IsingHamiltonian\", \"[\", StyleBox[\"hx\", \
\"TI\"], \",\", StyleBox[\"hz\", \"TI\"], \",\", StyleBox[\"J\", \"TI\"], \",\
\", StyleBox[\"L\", \"TI\"], \",\", StyleBox[\"Opts\", \"TI\"], \"]\"}], \"MR\
\"]\) returns the mixed-field Ising Hamiltonian of \!\(\*StyleBox[\"L\", \"TI\
\"]\) spins with transverse and longitudinal fields, respectively, \
\!\(\*StyleBox[RowBox[{SubscriptBox[\"h\", \"x\"]}], \"TI\"]\) and \
\!\(\*StyleBox[RowBox[{SubscriptBox[\"h\", \"z\"]}], \"TI\"]\), and coupling \
\!\(\*StyleBox[\"J\", \"TI\"]\). H = \[Sum] \
(\!\(\*StyleBox[RowBox[{SubscriptBox[\"h\", \"x\"]}], \"TI\"]\) \
\!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", \"i\"], RowBox[{\" \", \
\"x\"}]]\) + \!\(\*StyleBox[RowBox[{SubscriptBox[\"h\", \"z\"]}], \"TI\"]\) \
\!\(\*SuperscriptBox[SubscriptBox[\"\[Sigma]\", \"i\"], RowBox[{\" \", \
\"z\"}]]\)) - \!\(\*StyleBox[\"J\", \"TI\"]\) \[Sum] \
\!\(\*SubscriptBox[SuperscriptBox[\"\[Sigma]\", RowBox[{\" \", \"z\"}]], \
\"i\"]\) \!\(\*SubscriptBox[SuperscriptBox[\"\[Sigma]\", RowBox[{\" \", \
\"z\"}]], RowBox[{\"i\", \"+\", \"1\"}]]\).\n\
\!\(\*StyleBox[\"IsingHamiltonian\", \"MR\"]\) \!\(\*StyleBox[\"Options\", \
\"MR\"]\): BoundaryConditions, ParitySector, and MomentumSector (only with \
BoundaryConditions->\"Periodic\").\n\!\(\*StyleBox[\"IsingHamiltonian\", \"MR\
\"]\) More details in arxiv:2512.11030 [Eq. (9)].", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QMB`ManyBody`IsingHamiltonian, {QMB`ManyBody`IsingHamiltonian[
         Pattern[QMB`ManyBody`SpinChains`Private`hx, 
          Blank[]], 
         Pattern[QMB`ManyBody`SpinChains`Private`hz, 
          Blank[]], 
         Pattern[QMB`ManyBody`SpinChains`Private`J, 
          Blank[]], 
         Pattern[QMB`ManyBody`SpinChains`Private`L, 
          Blank[Integer]], 
         Pattern[QMB`ManyBody`SpinChains`Private`opts, 
          OptionsPattern[]]] :> 
       Module[{QMB`ManyBody`SpinChains`Private`bc, 
          QMB`ManyBody`SpinChains`Private`mom, 
          QMB`ManyBody`SpinChains`Private`par, 
          QMB`ManyBody`SpinChains`Private`HamFull}, 
         QMB`ManyBody`SpinChains`Private`bc = 
          OptionValue[QMB`ManyBody`BoundaryConditions]; 
         QMB`ManyBody`SpinChains`Private`mom = 
          OptionValue[QMB`ManyBody`MomentumSector]; 
         QMB`ManyBody`SpinChains`Private`par = 
          OptionValue[QMB`ManyBody`ParitySector]; If[
           Not[
            QMB`ManyBody`SpinChains`Private`ValidateHamiltonianOptions[
            QMB`ManyBody`SpinChains`Private`L, 
             QMB`ManyBody`SpinChains`Private`bc, 
             QMB`ManyBody`SpinChains`Private`mom, 
             QMB`ManyBody`SpinChains`Private`par, "All"]], 
           Return[$Failed]]; 
         QMB`ManyBody`SpinChains`Private`HamFull = 
          QMB`ManyBody`SpinChains`Private`TwoSiteSum[
            QMB`ManyBody`SpinChains`Private`J, 3, 
             QMB`ManyBody`SpinChains`Private`bc, 
             QMB`ManyBody`SpinChains`Private`L] + 
           QMB`ManyBody`SpinChains`Private`OneSiteSum[
            QMB`ManyBody`SpinChains`Private`hx, 1, 
             QMB`ManyBody`SpinChains`Private`L] + 
           QMB`ManyBody`SpinChains`Private`OneSiteSum[
            QMB`ManyBody`SpinChains`Private`hz, 3, 
             QMB`ManyBody`SpinChains`Private`L]; 
         QMB`ManyBody`SpinChains`Private`ProjectOperator[
          QMB`ManyBody`SpinChains`Private`HamFull, 
           QMB`ManyBody`SpinChains`Private`L, 
           QMB`ManyBody`SpinChains`Private`mom, 
           QMB`ManyBody`SpinChains`Private`par]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     QMB`ManyBody`BoundaryConditions -> "Open", QMB`ManyBody`MomentumSector -> 
      "All", QMB`ManyBody`ParitySector -> "None"}, "Attributes" -> {}, 
    "FullName" -> "QMB`ManyBody`IsingHamiltonian"|>, False]]], "Output",
