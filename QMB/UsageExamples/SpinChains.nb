         QMB`ManyBody`SpinChains`Private`bc = 
          OptionValue[QMB`ManyBody`BoundaryConditions]; 
         QMB`ManyBody`SpinChains`Private`mag = 
          OptionValue[QMB`ManyBody`MagnonSector]; If[
           Not[
            MatchQ[QMB`ManyBody`SpinChains`Private`bc, 
             Alternatives["Open", "Periodic"]]], Message[
             MessageName[QMB`ManyBody`XXZwLocalDefectHamiltonian, "badBC"], 
