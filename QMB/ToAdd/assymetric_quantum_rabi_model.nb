Cell[BoxData[{
 RowBox[{"ClearAll", "[", "ConvergenceQ", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ConvergenceQ", "[", 
   RowBox[{"v_", ",", "nMax_", ",", 
    RowBox[{"f_", ":", "0.1"}], ",", 
    RowBox[{"\[Epsilon]_", ":", 
     RowBox[{"10.", "^", 
      RowBox[{"-", "6"}]}]}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Chop", "[", 
    RowBox[{"Total", "[", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"Transpose", "[", 
          RowBox[{"Partition", "[", 
           RowBox[{"v", ",", 
            RowBox[{"nMax", "+", "1"}]}], "]"}], "]"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Floor", "[", 
            RowBox[{"2", 
             RowBox[{"(", 
              RowBox[{"nMax", "+", "1"}], ")"}], "*", "f"}], "]"}]}], ";;"}], 
         "]"}], "]"}], "]"}], "^", "2"}], "]"}], "]"}], "<=", 
   "\[Epsilon]"}]}]}], "Input",
 CellChangeTimes->{{3.971263416057626*^9, 3.9712634765782967`*^9}, {
  3.9712637503022833`*^9, 3.9712637648102007`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"c7c16a8f-a28a-448b-8cae-123e877ad59c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GoodEigenvectors", "[", "evecs_List", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{"nMax", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"evecs", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], "/", "2"}], "-", "1"}]}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"evecs", "[", 
     RowBox[{"[", 
      RowBox[{";;", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"LengthWhile", "[", 
           RowBox[{
            RowBox[{"Reverse", "[", "evecs", "]"}], ",", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"ConvergenceQ", "[", 
               RowBox[{"#", ",", "nMax"}], "]"}]}], "&"}]}], "]"}], "+", 
          "1"}], ")"}]}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.971264253603527*^9, 3.971264370122259*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"d8378b77-ef7e-4122-bd07-5e8cf5a28cf2"]
}, Closed]],

