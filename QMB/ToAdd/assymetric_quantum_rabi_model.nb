Cell[BoxData[{
 RowBox[{"ClearAll", "[", "TimeEvolutionDiagonal", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TimeEvolutionDiagonal", "[", 
   RowBox[{"H_", ",", "initialState_", ",", "tMax_", ",", "steps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"evals", ",", "evecs", ",", "coeffs", ",", "times"}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"Pre", "-", 
      RowBox[{"diagonalizar", " ", "UNA", " ", "sola", " ", "vez"}]}], "*)"}],
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"evals", ",", "evecs"}], "}"}], "=", 
      RowBox[{"Eigensystem", "[", 
       RowBox[{"Normal", "[", "H", "]"}], "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Proyectar", " ", "estado", " ", "inicial", " ", "en", " ", "base", " ",
        "propia"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"coeffs", "=", 
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{"Transpose", "[", "evecs", "]"}], "]"}], ".", 
       "initialState"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"times", "=", 
      RowBox[{"Subdivide", "[", 
       RowBox[{"0.0", ",", "tMax", ",", "steps"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"Braket", "[", 
              RowBox[{"initialState", ",", "#"}], "]"}], "]"}], "^", "2"}], 
           "&"}], "[", 
          RowBox[{"evecs", ".", 
           RowBox[{"(", 
            RowBox[{"coeffs", "*", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "I"}], "*", "evals", "*", "t"}], "]"}]}], ")"}]}],
           "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "times"}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.9699932616651163`*^9, 3.969993365181292*^9}, {
  3.9699934567823668`*^9, 3.9699934908375263`*^9}},
 CellLabel->
  "In[682]:=",ExpressionUUID->"501c503c-06b5-474f-be0e-3d4329c29cb4"],

