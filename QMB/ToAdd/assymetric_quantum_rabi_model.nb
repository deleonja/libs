Cell[BoxData[{
 RowBox[{
  RowBox[{"blochVectorT", "=", 
   RowBox[{"Normalize", "[", 
    RowBox[{"{", 
     RowBox[{"1.", ",", "1", ",", "1"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tstate", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pauli", "[", "0", "]"}], "+", 
      RowBox[{"blochVectorT", ".", 
       RowBox[{"(", 
        RowBox[{"Pauli", "/@", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], ")"}]}]}], ")"}], "/", 
    "2"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.969993967894409*^9, 3.969994037602985*^9}},
 CellLabel->
  "In[707]:=",ExpressionUUID->"c46a5f8d-2253-4bf8-b170-3b256117e05e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"initialState", "=", "\[Psi]0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tMax", "=", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"steps", "=", "100"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9699937624049997`*^9, 3.9699937853727913`*^9}, {
  3.969993851318068*^9, 3.9699938876292887`*^9}, {3.969994043524497*^9, 
  3.969994054365015*^9}, {3.969994095785548*^9, 3.969994104074614*^9}, {
  3.9699941535480967`*^9, 3.9699941538262653`*^9}, {3.969994210435313*^9, 
  3.969994210674241*^9}},
 CellLabel->
  "In[730]:=",ExpressionUUID->"fc586156-d96a-4d92-ae31-f320a2d6c12b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"distance", "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"evals", ",", "evecs", ",", "coeffs", ",", "times"}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Pre", "-", 
       RowBox[{"diagonalizar", " ", "UNA", " ", "sola", " ", "vez"}]}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"evals", ",", "evecs"}], "}"}], "=", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"Normal", "[", "H", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Proyectar", " ", "estado", " ", "inicial", " ", "en", " ", "base", " ",
         "propia"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"coeffs", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"Transpose", "[", "evecs", "]"}], "]"}], ".", 
        "initialState"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"times", "=", 
       RowBox[{"Subdivide", "[", 
        RowBox[{"0.0", ",", "tMax", ",", "steps"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Chop", "[", 
             RowBox[{"Tr", "[", 
              RowBox[{"Tstate", ".", "#"}], "]"}], "]"}], "&"}], "[", 
           RowBox[{"MatrixPartialTrace", "[", 
            RowBox[{
             RowBox[{"Dyad", "[", 
              RowBox[{"evecs", ".", 
               RowBox[{"(", 
                RowBox[{"coeffs", "*", 
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"-", "I"}], "*", "evals", "*", "t"}], "]"}]}], 
                ")"}]}], "]"}], ",", "2", ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", 
               RowBox[{"nMax", "+", "1"}]}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "times"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9699938047338667`*^9, 3.969993866708665*^9}, {
  3.9699940980956173`*^9, 3.969994159814248*^9}, {3.9699946041249638`*^9, 
  3.969994617403379*^9}, {3.96999478729242*^9, 3.969994806707993*^9}},
