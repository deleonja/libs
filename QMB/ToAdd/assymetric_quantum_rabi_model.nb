Cell[BoxData[
 RowBox[{
  RowBox[{"distance", "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"evals", ",", "evecs", ",", "coeffs", ",", "times"}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Pre", "-", 
       RowBox[{"diagonalizar", " ", "UNA", " ", "sola", " ", "vez"}]}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"evals", ",", "evecs"}], "}"}], "=", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"Normal", "[", "H", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Proyectar", " ", "estado", " ", "inicial", " ", "en", " ", "base", " ",
         "propia"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"coeffs", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"Transpose", "[", "evecs", "]"}], "]"}], ".", 
        "initialState"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"times", "=", 
       RowBox[{"Subdivide", "[", 
        RowBox[{"0.0", ",", "tMax", ",", "steps"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Chop", "[", 
             RowBox[{"Tr", "[", 
              RowBox[{"Tstate", ".", "#"}], "]"}], "]"}], "&"}], "[", 
           RowBox[{"MatrixPartialTrace", "[", 
            RowBox[{
             RowBox[{"Dyad", "[", 
              RowBox[{"evecs", ".", 
               RowBox[{"(", 
                RowBox[{"coeffs", "*", 
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"-", "I"}], "*", "evals", "*", "t"}], "]"}]}], 
                ")"}]}], "]"}], ",", "2", ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", 
               RowBox[{"nMax", "+", "1"}]}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "times"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9699938047338667`*^9, 3.969993866708665*^9}, {
  3.9699940980956173`*^9, 3.969994159814248*^9}, {3.9699946041249638`*^9, 
