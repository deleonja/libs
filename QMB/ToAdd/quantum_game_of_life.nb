        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"4", " ", 
             RowBox[{"s", "^", "2"}]}], ")"}]}], "/", "\[Pi]"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "0", ",", "2.5"}], "}"}]}], "]"}]}], 
