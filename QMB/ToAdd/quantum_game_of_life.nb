Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Histogram", "[", 
    RowBox[{
     RowBox[{"Differences", "[", 
      RowBox[{"unfolded", "[", "\"\<UnfoldedLevels\>\"", "]"}], "]"}], ",", 
     "Automatic", ",", "\"\<PDF\>\"", ",", 
     RowBox[{"PlotLabel", "->", "\"\<k=0, p=+1\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<s\>\"", ",", " ", "\"\<P(s)\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", "16"}], "]"}]}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PDF", "[", 
        RowBox[{
         RowBox[{"RayleighDistribution", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "/", "Pi"}], "]"}], "]"}], ",", "s"}], "]"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"32", "/", 
          RowBox[{"\[Pi]", "^", "2"}]}], ")"}], " ", 
        RowBox[{"s", "^", "2"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"4", " ", 
             RowBox[{"s", "^", "2"}]}], ")"}]}], "/", "\[Pi]"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "0", ",", "3"}], "}"}]}], "]"}]}], 
