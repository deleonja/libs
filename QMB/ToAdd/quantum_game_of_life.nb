                    "]"}]}], "]"}], ",", "QMB`Private`dim"}], "]"}]}], ";", 
                    RowBox[{"QMB`Private`vProj", "=", 
                    RowBox[{"QMB`Private`v", "+", 
                    RowBox[{"QMB`Private`p", " ", "QMB`Private`vInv"}]}]}], 
                    ";", 
                    RowBox[{"If", "[", 
