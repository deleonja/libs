                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"QuantumGameOfLifeHamiltonian", "[", 
                    RowBox[{"QMB`Private`L_Integer", ",", 
                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`k", "=", 
                    RowBox[{"OptionValue", "[", "Momentum", "]"}]}], ",", 
                    RowBox[{"QMB`Private`p", "=", 
                    RowBox[{"OptionValue", "[", "Parity", "]"}]}], ",", 
                    RowBox[{"QMB`Private`dim", "=", 
                    SuperscriptBox["2", "QMB`Private`L"]}], ",", 
                    "QMB`Private`Hfull", ",", "QMB`Private`rules", ",", 
                    "QMB`Private`basisVectors", ",", "QMB`Private`P"}], "}"}],
                     ",", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`k", "=!=", "\"All\""}], "&&", 
                    RowBox[{"!", 
                    RowBox[{"IntegerQ", "[", "QMB`Private`k", "]"}]}]}], ",", 
                    
                    RowBox[{"Return", "[", 
                    RowBox[{
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"QuantumGameOfLifeHamiltonian", "::", "invMom"}], 
                    "MessageName"], ",", "QMB`Private`k"}], "]"}], ";", 
                    "$Failed"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`p", "=!=", "\"None\""}], "&&", 
                    RowBox[{"!", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"1", ",", 
                    RowBox[{"-", "1"}]}], "}"}], ",", "QMB`Private`p"}], 
                    "]"}]}]}], ",", 
                    RowBox[{"Return", "[", 
                    RowBox[{
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"QuantumGameOfLifeHamiltonian", "::", "invPar"}], 
                    "MessageName"], ",", "QMB`Private`p"}], "]"}], ";", 
                    "$Failed"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"IntegerQ", "[", "QMB`Private`k", "]"}], "&&", 
                    RowBox[{"QMB`Private`p", "=!=", "\"None\""}]}], ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`k", "\[NotEqual]", "0"}], "&&", 
                    RowBox[{"QMB`Private`k", "\[NotEqual]", 
                    FractionBox["QMB`Private`L", "2"]}]}], ",", 
                    RowBox[{
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    
                    RowBox[{"QuantumGameOfLifeHamiltonian", "::", 
                    "parityWarning"}], "MessageName"], ",", "QMB`Private`k"}],
                     "]"}], ";"}]}], "]"}]}], "]"}], ";", 
                    RowBox[{"QMB`Private`rules", "=", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`n", "=", "QMB`Private`state"}], ",", 
                    
                    RowBox[{"QMB`Private`flips", "=", 
                    RowBox[{"{", "}"}]}], ",", "QMB`Private`neighborsSum"}], 
                    "}"}], ",", 
                    RowBox[{
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`neighborsSum", "=", 
                    RowBox[{
                    RowBox[{"BitGet", "[", 
                    RowBox[{"QMB`Private`n", ",", 
                    RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`i", "-", "2"}], ",", 
                    "QMB`Private`L"}], "]"}]}], "]"}], "+", 
                    RowBox[{"BitGet", "[", 
                    RowBox[{"QMB`Private`n", ",", 
                    RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`i", "-", "1"}], ",", 
                    "QMB`Private`L"}], "]"}]}], "]"}], "+", 
                    RowBox[{"BitGet", "[", 
                    RowBox[{"QMB`Private`n", ",", 
                    RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`i", "+", "1"}], ",", 
                    "QMB`Private`L"}], "]"}]}], "]"}], "+", 
                    RowBox[{"BitGet", "[", 
                    RowBox[{"QMB`Private`n", ",", 
                    RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`i", "+", "2"}], ",", 
                    "QMB`Private`L"}], "]"}]}], "]"}]}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`neighborsSum", "\[Equal]", "2"}], 
                    "||", 
                    RowBox[{"QMB`Private`neighborsSum", "\[Equal]", "3"}]}], 
                    ",", 
                    RowBox[{"AppendTo", "[", 
                    RowBox[{"QMB`Private`flips", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`n", "+", "1"}], ",", 
                    RowBox[{
                    RowBox[{"BitXor", "[", 
                    RowBox[{"QMB`Private`n", ",", 
                    SuperscriptBox["2", "QMB`Private`i"]}], "]"}], "+", 
                    "1"}]}], "}"}], "\[Rule]", "1.`"}]}], "]"}]}], "]"}]}], 
                    ",", 
                    RowBox[{"{", 
                    RowBox[{"QMB`Private`i", ",", "0", ",", 
                    RowBox[{"QMB`Private`L", "-", "1"}]}], "}"}]}], "]"}], 
                    ";", "QMB`Private`flips"}]}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"QMB`Private`state", ",", "0", ",", 
                    RowBox[{"QMB`Private`dim", "-", "1"}]}], "}"}]}], "]"}], 
                    "]"}]}], ";", 
                    RowBox[{"QMB`Private`Hfull", "=", 
                    RowBox[{"SparseArray", "[", 
                    RowBox[{"QMB`Private`rules", ",", 
                    RowBox[{"{", 
                    RowBox[{"QMB`Private`dim", ",", "QMB`Private`dim"}], 
                    "}"}]}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`k", "===", "\"All\""}], ",", 
                    RowBox[{"Return", "[", "QMB`Private`Hfull", "]"}]}], 
                    "]"}], ";", 
                    RowBox[{"QMB`Private`basisVectors", "=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"QMB`Private`necklaces", ",", 
                    "QMB`Private`kBasis"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"QMB`Private`necklaces", "=", 
                    RowBox[{"GroupBy", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"0", ",", 
                    RowBox[{"QMB`Private`dim", "-", "1"}]}], "]"}], ",", 
                    RowBox[{"Function", "[", 
                    RowBox[{"QMB`Private`x", ",", 
                    RowBox[{"Min", "[", 
                    RowBox[{"NestList", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`RotateLeftBits", "[", 
                    RowBox[{"#1", ",", "QMB`Private`L"}], "]"}], "&"}], ",", 
                    "QMB`Private`x", ",", 
                    RowBox[{"QMB`Private`L", "-", "1"}]}], "]"}], "]"}]}], 
                    "]"}]}], "]"}]}], ";", 
                    RowBox[{"QMB`Private`kBasis", "=", 
                    RowBox[{
                    RowBox[{"Reap", "[", 
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`orbit", "=", "QMB`Private`members"}],
                     ",", "QMB`Private`R", ",", "QMB`Private`vec"}], "}"}], 
                    ",", 
                    RowBox[{
                    RowBox[{"QMB`Private`R", "=", 
                    RowBox[{"Length", "[", "QMB`Private`orbit", "]"}]}], ";", 
                    
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"Divisible", "[", 
                    RowBox[{
                    RowBox[{"QMB`Private`k", " ", "QMB`Private`R"}], ",", 
                    "QMB`Private`L"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"QMB`Private`vec", "=", 
                    RowBox[{"SparseArray", "[", 
                    RowBox[{
                    RowBox[{"{", "}"}], ",", "QMB`Private`dim"}], "]"}]}], 
                    ";", 
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"QMB`Private`vec", "=", 
                    RowBox[{"QMB`Private`vec", "+", 
                    RowBox[{"SparseArray", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`orbit", "\[LeftDoubleBracket]", 
                    RowBox[{"QMB`Private`j", "+", "1"}], 
                    "\[RightDoubleBracket]"}], "+", "1"}], "}"}], "\[Rule]", 
                    RowBox[{"Exp", "[", 
                    RowBox[{"-", 
                    FractionBox[
                    
                    RowBox[{"\[ImaginaryI]", " ", "2.`", " ", "\[Pi]", " ", 
                    "QMB`Private`k", " ", "QMB`Private`j"}], 
                    "QMB`Private`L"]}], "]"}]}], ",", "QMB`Private`dim"}], 
                    "]"}]}]}], ";"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"QMB`Private`j", ",", "0", ",", 
                    RowBox[{"QMB`Private`R", "-", "1"}]}], "}"}]}], "]"}], 
                    ";", 
                    RowBox[{"Sow", "[", 
                    RowBox[{"Normalize", "[", "QMB`Private`vec", "]"}], "]"}],
