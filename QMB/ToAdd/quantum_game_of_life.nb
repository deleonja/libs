          RowBox[{"\[Pi]", "^", "2"}]}], ")"}], " ", 
        RowBox[{"s", "^", "2"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"4", " ", 
             RowBox[{"s", "^", "2"}]}], ")"}]}], "/", "\[Pi]"}], "]"}]}]}], 
