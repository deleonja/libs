                    StyleBox[
                    RowBox[{"QuantumGameOfLifeHamiltonian", "::", "invPar"}], 
                    "MessageName"], ",", "QMB`Private`p"}], "]"}], ";", 
                    "$Failed"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
