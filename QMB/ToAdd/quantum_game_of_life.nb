                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"QMB`Private`k", "=", 
                    RowBox[{"OptionValue", "[", "Momentum", "]"}]}], ",", 
