   "ObjectType" -> "Symbol", "Usage" -> 
    "\!\(\*StyleBox[RowBox[{\"QuantumGameOfLifeHamiltonian\", \"[\", \
StyleBox[\"L\", \"TI\"], \",\", StyleBox[\"opts\", \"TI\"], \"]\"}], \
\"MR\"]\) returns the Hamiltonian for the Quantum Game of Life (QGL)   model \
for a spin-1/2 chain of length \!\(\*StyleBox[\"L\", \"TI\"]\) \
(arXiv:2510.16570):\n\!\(\)  H = \[Sum] \!\(\*SuperscriptBox[SubscriptBox[\"\
\[Sigma]\", \"i\"], \"x\"]\) \
(\!\(\*SuperscriptBox[SubscriptBox[\"\[ScriptN]\", \"i\"], \"2\"]\) + \
\!\(\*SuperscriptBox[SubscriptBox[\"\[ScriptN]\", \"i\"], \"3\"]\)).\n\!\(\)  \
\n\!\(\)  Options:\n\!\(\)  Momentum -> \"All\" (default) | Integer k (0 <= k \
< L).\n\!\(\)  Parity -> \"None\" (default) | 1 | -1.\n\!\(\)  \n\!\(\)  \
Note: Parity projection (Inversion Symmetry) is only valid for Momentum \
sectors k=0 or k=L/2.", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QMB`QuantumGameOfLifeHamiltonian, {
      QMB`QuantumGameOfLifeHamiltonian[
         Pattern[QMB`Private`L, 
          Blank[Integer]], 
         OptionsPattern[]] :> 
       Module[{QMB`Private`k = OptionValue[QMB`Momentum], QMB`Private`p = 
          OptionValue[QMB`Parity], QMB`Private`dim = 2^QMB`Private`L, 
          QMB`Private`Hfull, QMB`Private`rules, QMB`Private`basisVectors, 
          QMB`Private`P}, If[
           And[QMB`Private`k =!= "All", 
            Not[
             IntegerQ[QMB`Private`k]]], 
           Return[Message[
              MessageName[QMB`QuantumGameOfLifeHamiltonian, "invMom"], 
              QMB`Private`k]; $Failed]]; If[
           And[QMB`Private`p =!= "None", 
            Not[
             MemberQ[{1, -1}, QMB`Private`p]]], 
           Return[Message[
              MessageName[QMB`QuantumGameOfLifeHamiltonian, "invPar"], 
              QMB`Private`p]; $Failed]]; If[
           And[
            IntegerQ[QMB`Private`k], QMB`Private`p =!= "None"], 
           If[
            And[QMB`Private`k != 0, QMB`Private`k != QMB`Private`L/2], Message[
              MessageName[QMB`QuantumGameOfLifeHamiltonian, "parityWarning"], 
              QMB`Private`k]; Null]]; QMB`Private`rules = Flatten[
            Table[
             
             Module[{QMB`Private`n = QMB`Private`state, 
               QMB`Private`flips = {}, QMB`Private`neighborsSum}, 
              Do[QMB`Private`neighborsSum = BitGet[QMB`Private`n, 
                    Mod[QMB`Private`i - 2, QMB`Private`L]] + 
                  BitGet[QMB`Private`n, 
                    Mod[QMB`Private`i - 1, QMB`Private`L]] + 
                  BitGet[QMB`Private`n, 
                    Mod[QMB`Private`i + 1, QMB`Private`L]] + 
                  BitGet[QMB`Private`n, 
                    Mod[QMB`Private`i + 2, QMB`Private`L]]; If[
                  Or[
                  QMB`Private`neighborsSum == 2, QMB`Private`neighborsSum == 
                   3], 
                  AppendTo[
                  QMB`Private`flips, {
                    QMB`Private`n + 1, BitXor[QMB`Private`n, 2^QMB`Private`i] + 
                    1} -> 1.]], {QMB`Private`i, 0, QMB`Private`L - 1}]; 
              QMB`Private`flips], {
             QMB`Private`state, 0, QMB`Private`dim - 1}]]; 
         QMB`Private`Hfull = 
          SparseArray[QMB`Private`rules, {QMB`Private`dim, QMB`Private`dim}]; 
         If[QMB`Private`k === "All", 
           Return[QMB`Private`Hfull]]; 
         QMB`Private`basisVectors = 
          Module[{QMB`Private`necklaces, QMB`Private`kBasis}, 
            QMB`Private`necklaces = GroupBy[
               Range[0, QMB`Private`dim - 1], 
               Function[QMB`Private`x, 
                Min[
                 NestList[
                 QMB`Private`RotateLeftBits[#, QMB`Private`L]& , 
                  QMB`Private`x, QMB`Private`L - 1]]]]; 
            QMB`Private`kBasis = Part[
               Reap[
                Do[
                 
                 Module[{
                  QMB`Private`orbit = QMB`Private`members, QMB`Private`R, 
                   QMB`Private`vec}, 
                  QMB`Private`R = Length[QMB`Private`orbit]; If[
                    Divisible[QMB`Private`k QMB`Private`R, QMB`Private`L], 
                    QMB`Private`vec = SparseArray[{}, QMB`Private`dim]; 
                    Do[QMB`Private`vec = 
                    QMB`Private`vec + 
                    SparseArray[{
                    Part[QMB`Private`orbit, QMB`Private`j + 1] + 1} -> 
                    Exp[(-I) 2. Pi 
                    QMB`Private`k (QMB`Private`j/QMB`Private`L)], 
                    QMB`Private`dim]; Null, {
                    QMB`Private`j, 0, QMB`Private`R - 1}]; Sow[
                    Normalize[QMB`Private`vec]]; Null]], {QMB`Private`members, 
                  Values[QMB`Private`necklaces]}]], 2]; 
            If[QMB`Private`kBasis === {}, 
              Return[
               SparseArray[{}, {0, 0}]]]; Flatten[QMB`Private`kBasis, 1]]; 
         If[QMB`Private`p =!= "None", QMB`Private`basisVectors = Part[
              Reap[
               Scan[
                Function[QMB`Private`v, 
                 
                 Module[{QMB`Private`vInv, QMB`Private`vProj}, 
                  QMB`Private`vInv = SparseArray[
                    Thread[
                    Map[QMB`Private`ReverseBits[# - 1, QMB`Private`L] + 1& , 
                    Part[
                    QMB`Private`v["NonzeroPositions"], All, 1]] -> 
                    QMB`Private`v["NonzeroValues"]], QMB`Private`dim]; 
                  QMB`Private`vProj = 
                   QMB`Private`v + QMB`Private`p QMB`Private`vInv; 
                  If[Norm[QMB`Private`vProj] > 10^(-10), 
                    Sow[
                    Normalize[QMB`Private`vProj]]]; Null]], 
                QMB`Private`basisVectors]], 2]; 
           If[QMB`Private`basisVectors =!= {}, 
             QMB`Private`basisVectors = DeleteDuplicates[
                Flatten[QMB`Private`basisVectors, 1], Or[
                Norm[# - #2] < 10^(-8), Norm[# + #2] < 10^(-8)]& ]; Null, 
             Return[
              SparseArray[{}, {0, 0}]]]; Null]; QMB`Private`P = Transpose[
            SparseArray[QMB`Private`basisVectors]]; Chop[
           Dot[
            ConjugateTranspose[QMB`Private`P], QMB`Private`Hfull, 
            QMB`Private`P]]]}], "SubValues" -> None, "DefaultValues" -> None, 
    "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {QMB`Momentum -> "All", QMB`Parity -> "None"}, 
    "Attributes" -> {}, "FullName" -> "QMB`QuantumGameOfLifeHamiltonian"|>, 
   False]]], "Output",
