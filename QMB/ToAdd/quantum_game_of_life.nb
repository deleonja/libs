Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Histogram", "[", 
    RowBox[{
     RowBox[{"Differences", "[", 
      RowBox[{"unfolded", "[", "\"\<UnfoldedLevels\>\"", "]"}], "]"}], ",", 
     "Automatic", ",", "\"\<PDF\>\"", ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"k\", \"TI\"], \"\[LongEqual]\", \"2\"}], TraditionalForm], \
\"errors\" -> {}, \"input\" -> \"k=2\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
StyleBox[\"s\", \"TI\"], TraditionalForm], \"errors\" -> {}, \"input\" -> \"s\
\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", 
        " ", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"P\", \"TI\"], \"(\", 
StyleBox[\"s\", \"TI\"], \")\"}], TraditionalForm], \"errors\" -> {}, \"input\
\" -> \"P (s)\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\""}], 
       "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", "16"}], "]"}]}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PDF", "[", 
        RowBox[{
         RowBox[{"RayleighDistribution", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "/", "Pi"}], "]"}], "]"}], ",", "s"}], "]"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"32", "/", 
          RowBox[{"\[Pi]", "^", "2"}]}], ")"}], " ", 
        RowBox[{"s", "^", "2"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"4", " ", 
             RowBox[{"s", "^", "2"}]}], ")"}]}], "/", "\[Pi]"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "0", ",", "2.5"}], "}"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
