Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Par\[AAcute]metros", " ", "de", " ", "prueba"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"numQubits", " ", "=", " ", "14"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Aumentamos", " ", "para", " ", "notar", " ", "el", " ", "impacto", " ", 
     "de", " ", "la", " ", "vectorizaci\[OAcute]n"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"targetQubit", " ", "=", " ", "2"}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"bVec", " ", "=", " ", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", "3"}], "]"}]}],
     ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Estado", " ", "aleatorio", " ", "normalizado", " ", "complejo"}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"state", " ", "=", " ", 
     RowBox[{"RandomChainProductState", "[", "numQubits", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JCoupling", " ", "=", " ", 
     RowBox[{"RandomReal", "[", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pos1", " ", "=", " ", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pos2", " ", "=", " ", "5"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<--- TEST ISING CHAIN ---\>\"", "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{" ", "A", ")"}], " ", "Paquete", " ", "Original", " ", 
     RowBox[{"(", 
      RowBox[{"Doble", " ", "bucle", " ", 
       RowBox[{"For", ":", " ", 
        RowBox[{"N", " ", "Qubits", " ", "x", " ", 
         RowBox[{"2", "^", "N"}], " ", "Estados"}]}]}], ")"}]}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tOldChain", ",", " ", "oldStateChain"}], "}"}], " ", "=", " ", 
     "\n", "  ", 
     RowBox[{"RepeatedTiming", "[", "\n", "   ", 
      RowBox[{"SpinChain`ApplyIsingChain", "[", 
       RowBox[{"state", ",", " ", "JCoupling"}], "]"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{" ", "B", ")"}], " ", "Nuevo", " ", "Paquete", " ", "QMB", " ", 
     RowBox[{"(", 
      RowBox[{
      "Operaci\[OAcute]n", " ", "anal\[IAcute]tica", " ", "de", " ", "bits", " ",
        "O", 
       RowBox[{"(", "1", ")"}], " ", "loopless"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tNewChain", ",", " ", "newStateChain"}], "}"}], " ", "=", " ", 
     "\n", "  ", 
     RowBox[{"RepeatedTiming", "[", "\n", "   ", 
      RowBox[{"QMB`ManyBody`ApplyPeriodicIsingInteraction", "[", 
       RowBox[{"state", ",", " ", "JCoupling"}], "]"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", " ", 
       RowBox[{"VectorQ", "[", 
        RowBox[{"newStateChain", ",", " ", "NumericQ"}], "]"}]}], ",", "\n", 
      "      ", 
      RowBox[{
      "Print", "[", "\"\<\[WarningSign] ERROR: La funci\[OAcute]n nueva no se \
evalu\[OAcute].\>\"", "]"}], ",", "\n", "      ", "\n", "      ", 
      RowBox[{"(*", " ", 
       RowBox[{"Resultados", " ", "Test", " ", "4"}], " ", "*)"}], "\n", 
      "      ", 
      RowBox[{
       RowBox[{"diffChain", " ", "=", " ", 
        RowBox[{"Norm", "[", 
         RowBox[{"newStateChain", " ", "-", " ", "oldStateChain"}], "]"}]}], ";",
        "\n", "      ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Diferencia (Norma): \>\"", ",", " ", "diffChain"}], 
        "]"}], ";", "\n", "      ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<\[DownQuestion]Resultados id\[EAcute]nticos?: \>\"", ",",
          " ", 
         RowBox[{
          RowBox[{"Chop", "[", "diffChain", "]"}], " ", "==", " ", "0"}]}], 
        "]"}], ";", "\n", "      ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Tiempo promedio vieja rutina: \>\"", ",", " ", 
         "tOldChain", ",", " ", "\"\< s\>\""}], "]"}], ";", "\n", "      ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Tiempo promedio nueva rutina: \>\"", ",", " ", 
         "tNewChain", ",", " ", "\"\< s\>\""}], "]"}], ";", "\n", "      ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tNewChain", " ", "<", " ", "tOldChain"}], ",", " ", "\n", 
         "           ", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<\[DownExclamation]El nuevo es \>\"", ",", " ", 
           RowBox[{"Round", "[", 
            RowBox[{"tOldChain", "/", 
             RowBox[{"Max", "[", 
              RowBox[{"tNewChain", ",", " ", 
               RowBox[{"10", "^", 
                RowBox[{"-", "6"}]}]}], "]"}]}], "]"}], ",", 
           " ", "\"\<x m\[AAcute]s r\[AAcute]pido!\>\""}], "]"}]}], "\n", 
        "       ", "]"}], ";"}]}], "\n", "  ", "]"}], ";"}]}]}]], "Input",
