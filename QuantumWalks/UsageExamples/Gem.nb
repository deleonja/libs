Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"createFrame", "[", "stepIndex_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "plotData", ",", " ", "currentProbs", ",", " ", "exactAspectRatio"}], 
      "}"}], ",", "\n", "    ", "\n", "    ", 
     RowBox[{
      RowBox[{"currentProbs", " ", "=", " ", 
       RowBox[{"probabilityDistributions", "[", 
        RowBox[{"[", "stepIndex", "]"}], "]"}]}], ";", "\n", "    ", 
      RowBox[{"plotData", " ", "=", " ", 
       RowBox[{"MapThread", "[", 
        RowBox[{"Append", ",", " ", 
         RowBox[{"{", 
          RowBox[{"coords", ",", " ", "currentProbs"}], "}"}]}], "]"}]}], ";",
       "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculamos", " ", "la", " ", "relaci\[OAcute]n", " ", "de", " ", 
        "aspecto", " ", "f\[IAcute]sica", " ", "estricta", " ", 
        RowBox[{"(", 
         RowBox[{"Alto", " ", "/", " ", "Ancho"}], ")"}]}], " ", "*)"}], "\n",
       "    ", 
      RowBox[{"exactAspectRatio", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"radiusR", " ", "+", " ", "1"}], ")"}], " ", "/", " ", 
        RowBox[{"(", 
         RowBox[{"lengthL", " ", "+", " ", "radiusR", " ", "+", " ", "1"}], 
         ")"}]}]}], ";", "\n", "    ", "\n", "    ", 
      RowBox[{"ListDensityPlot", "[", 
       RowBox[{"plotData", ",", "\n", "        ", 
        RowBox[{"ColorFunctionScaling", " ", "->", " ", "False"}], ",", "\n", 
        "        ", "\n", "        ", 
        RowBox[{"(*", " ", 
         RowBox[{"Invertimos", " ", 
          RowBox[{"Magma", ":", " ", 
           RowBox[{"1", " ", "-", " ", "valor_normalizado"}]}]}], " ", "*)"}],
         "\n", "        ", 
        RowBox[{"ColorFunction", " ", "->", " ", 
         RowBox[{"Function", "[", 
          RowBox[{"prob", ",", " ", "\n", "            ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"prob", " ", "<=", " ", "probMin"}], ",", " ", "\n", 
             "                ", "White", ",", " ", "\n", "                ", 
             
             RowBox[{
              RowBox[{"ColorData", "[", "\"\<Magma\>\"", "]"}], "[", 
              RowBox[{"1", " ", "-", " ", 
               RowBox[{"Clip", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Log10", "[", "prob", "]"}], " ", "-", " ", 
                    "logPMin"}], ")"}], " ", "/", " ", 
                  RowBox[{"(", 
                   RowBox[{"logPMax", " ", "-", " ", "logPMin"}], ")"}]}], ",",
                  " ", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], "]"}]}], 
            "\n", "            ", "]"}]}], "\n", "        ", "]"}]}], ",", 
        "\n", "        ", "\n", "        ", 
        RowBox[{"PlotRange", " ", "->", " ", 
         RowBox[{"{", "\n", "            ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{
               "lengthL", " ", "+", " ", "radiusR", " ", "+", " ", "1"}], 
               ")"}]}], ",", " ", 
             RowBox[{
             "lengthL", " ", "+", " ", "radiusR", " ", "+", " ", "1"}]}], 
            "}"}], ",", " ", "\n", "            ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{"radiusR", " ", "+", " ", "1"}], ")"}]}], ",", " ", 
             RowBox[{"radiusR", " ", "+", " ", "1"}]}], "}"}], ",", " ", "\n",
            "            ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "maxProb"}], "}"}]}], "\n", "        ", 
          "}"}]}], ",", "\n", "        ", 
        RowBox[{"Mesh", " ", "->", " ", "False"}], ",", "\n", "        ", 
        RowBox[{"InterpolationOrder", " ", "->", " ", "0"}], ",", " ", "\n", 
        "        ", 
        RowBox[{"FrameLabel", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\""}], "}"}]}], ",", "\n", 
        "        ", 
        RowBox[{"PlotLabel", " ", "->", " ", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"\"\<Full Bunimovich Stadium | t = \>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", 
             RowBox[{"stepIndex", " ", "-", " ", "1"}], "]"}]}], ",", " ", 
           "16", ",", " ", "Bold"}], "]"}]}], ",", "\n", "        ", 
        RowBox[{"ImageSize", " ", "->", " ", "Large"}], ",", "\n", "        ",
         "\n", "        ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Retornamos", " ", "a", " ", "un", " ", "fondo", " ", "blanco", " ", 
          "y", " ", "ejes", " ", "negros"}], " ", "*)"}], "\n", "        ", 
        RowBox[{"Background", " ", "->", " ", "White"}], ",", " ", "\n", 
        "        ", 
        RowBox[{"LabelStyle", " ", "->", " ", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", " ", "20"}], "]"}]}], ",", " ", "\n", 
        "        ", 
        RowBox[{"AxesStyle", " ", "->", " ", "Black"}], ",", "\n", "        ", 
        RowBox[{"FrameStyle", " ", "->", " ", "Black"}], ",", "\n", 
        "        ", "\n", "        ", 
        RowBox[{"PlotLegends", " ", "->", " ", 
         RowBox[{"Placed", "[", "\n", "            ", 
          RowBox[{
           RowBox[{"BarLegend", "[", 
            RowBox[{
             RowBox[{"{", "\n", "                ", 
              RowBox[{"(*", " ", 
               RowBox[{
               "La", " ", "leyenda", " ", "tambi\[EAcute]n", " ", "debe", " ",
                 "usar", " ", "la", " ", "funci\[OAcute]n", " ", 
                "invertida"}], " ", "*)"}], "\n", "                ", 
              RowBox[{
               RowBox[{"Function", "[", 
                RowBox[{"logProb", ",", " ", "\n", "                    ", 
                 RowBox[{
                  RowBox[{"ColorData", "[", "\"\<Magma\>\"", "]"}], "[", 
                  RowBox[{"1", " ", "-", " ", 
                   RowBox[{"Clip", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"logProb", " ", "-", " ", "logPMin"}], ")"}], " ",
                     "/", " ", 
                    RowBox[{"(", 
                    RowBox[{"logPMax", " ", "-", " ", "logPMin"}], ")"}]}], ",",
                     " ", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], "]"}]}], 
                "\n", "                ", "]"}], ",", " ", "\n", 
               "                ", 
               RowBox[{"{", 
                RowBox[{"logPMin", ",", " ", "logPMax"}], "}"}]}], "\n", 
              "            ", "}"}], ",", " ", "\n", "            ", 
             RowBox[{"Ticks", " ", "->", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"#", ",", " ", 
                   RowBox[{"Superscript", "[", 
                    RowBox[{"10", ",", " ", "#"}], "]"}]}], "}"}], " ", "&"}],
                 " ", "/@", " ", 
                RowBox[{"Range", "[", 
                 RowBox[{
                  RowBox[{"Round", "[", "logPMin", "]"}], ",", " ", 
                  RowBox[{"Ceiling", "[", "logPMax", "]"}]}], "]"}]}], 
               ")"}]}], ",", "\n", "            ", 
             RowBox[{"LegendLabel", " ", "->", " ", 
              RowBox[{"Style", "[", 
               
               RowBox[{"\"\<Probability\>\"", ",", " ", "14", ",", " ", 
                "Black"}], "]"}]}], ",", " ", "\n", "            ", 
             RowBox[{"LabelStyle", " ", "->", " ", 
              RowBox[{"Directive", "[", 
               RowBox[{"Black", ",", " ", "14"}], "]"}]}], ",", "\n", 
             "            ", 
             RowBox[{"LegendMarkerSize", " ", "->", " ", "300"}]}], "]"}], ",",
            " ", "\n", "            ", "Right"}], "\n", "        ", "]"}]}], ",",
         "\n", "        ", "\n", "        ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Obligamos", " ", "a", " ", "Mathematica", " ", "a", " ", "usar", " ",
           "la", " ", "proporci\[OAcute]n", " ", "f\[IAcute]sica", " ", 
          "exacta"}], " ", "*)"}], "\n", "        ", 
        RowBox[{"AspectRatio", " ", "->", " ", "exactAspectRatio"}], ",", 
        "\n", "        ", "\n", "        ", 
        RowBox[{"RegionFunction", " ", "->", " ", 
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", " ", "y", ",", " ", "prob"}], "}"}], ",", "\n", 
           "            ", 
           RowBox[{
            RowBox[{"Abs", "[", "y", "]"}], " ", "<=", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", "x", "]"}], " ", "<=", " ", "lengthL"}], ",",
               " ", "\n", "                          ", "radiusR", ",", " ", 
              "\n", "                          ", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"Max", "[", 
                RowBox[{"0", ",", " ", 
                 RowBox[{
                  RowBox[{"radiusR", "^", "2"}], " ", "-", " ", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Abs", "[", "x", "]"}], " ", "-", " ", 
                    "lengthL"}], ")"}], "^", "2"}]}]}], "]"}], "]"}]}], "\n", 
             "                      ", "]"}]}]}], "\n", "        ", "]"}]}], ",",
         "\n", "        ", "\n", "        ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Fronteras", " ", "del", " ", "estadio", " ", "de", " ", "vuelta", " ",
           "a", " ", "negro", " ", "para", " ", "hacer", " ", "contraste"}], 
         " ", "*)"}], "\n", "        ", 
        RowBox[{"Epilog", " ", "->", " ", 
         RowBox[{"{", "\n", "            ", 
          RowBox[{
           RowBox[{"Directive", "[", 
            RowBox[{"Thick", ",", " ", "Black"}], "]"}], ",", "\n", 
           "            ", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "lengthL"}], ",", " ", "radiusR"}], "}"}], ",", 
              " ", 
              RowBox[{"{", 
               RowBox[{"lengthL", ",", " ", "radiusR"}], "}"}]}], "}"}], 
            "]"}], ",", "   ", "\n", "            ", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "lengthL"}], ",", " ", 
                RowBox[{"-", "radiusR"}]}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"lengthL", ",", " ", 
                RowBox[{"-", "radiusR"}]}], "}"}]}], "}"}], "]"}], ",", " ", 
           "\n", "            ", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"lengthL", ",", " ", "0"}], "}"}], ",", " ", "radiusR", 
             ",", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "Pi"}], "/", "2"}], ",", " ", 
               RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}], ",", "      ", 
           "\n", "            ", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "lengthL"}], ",", " ", "0"}], "}"}], ",", " ", 
             "radiusR", ",", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Pi", "/", "2"}], ",", " ", 
               RowBox[{"3", " ", 
                RowBox[{"Pi", "/", "2"}]}]}], "}"}]}], "]"}]}], "     ", "\n",
           "        ", "}"}]}]}], "\n", "    ", "]"}]}]}], "\n", "]"}]}], 
