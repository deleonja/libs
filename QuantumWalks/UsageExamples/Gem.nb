Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"4.", " ", "State", " ", "Initialization", " ", 
    RowBox[{"(", 
     RowBox[{"Symmetric", " ", "State"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "We", " ", "place", " ", "the", " ", "initial", " ", "state", " ", "on", " ",
     "the", " ", "symmetry", " ", "axis", " ", "so", " ", "it", " ", 
    "intrinsically", " ", "has", " ", "even", " ", "parity"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"centerCoord", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "radiusR"}], ",", " ", "0"}], "}"}]}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"centerIndex", " ", "=", " ", 
     RowBox[{
      RowBox[{"gridData", "[", "\"\<Mapping\>\"", "]"}], "[", "centerCoord", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Initializing", " ", "in", " ", "the", " ", "\"\<Up\>\"", " ", "state", " ",
      "at", " ", "the", " ", "specified", " ", "node", " ", "in", " ", "FULL",
      " ", "space"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"initialStateFull", " ", "=", " ", 
     RowBox[{"SparseArray", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"4", " ", "*", " ", 
           RowBox[{"(", 
            RowBox[{"centerIndex", " ", "-", " ", "1"}], ")"}]}], " ", "+", 
          " ", "1"}], " ", "->", " ", 
         RowBox[{"1.0", " ", "+", " ", 
          RowBox[{"0.", "I"}]}]}], "}"}], ",", " ", 
       RowBox[{"4", " ", "*", " ", "dimSpace"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Project", " ", "the", " ", "initial", " ", "state", " ", "down", " ", 
     "into", " ", "the", " ", "reduced", " ", "subspace", " ", "and", " ", 
     "normalize"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"initialStateRed", " ", "=", " ", 
     RowBox[{"Normalize", "[", 
      RowBox[{"Chop", "[", 
       RowBox[{
        RowBox[{"ConjugateTranspose", "[", "isometryV", "]"}], " ", ".", " ", 
        "initialStateFull"}], "]"}], "]"}]}], ";"}], "\n"}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10002.},
 CellChangeTimes->{{3.981482991397875*^9, 3.9814830082547407`*^9}, {
