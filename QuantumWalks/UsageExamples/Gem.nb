Cell[CellGroupData[{

Cell["Cardioid", "Section",
 CellChangeTimes->{{3.981482858586904*^9, 
  3.9814828601157007`*^9}},ExpressionUUID->"d0f7c956-7e41-4b03-a812-\
845fa7fcce0c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Define", " ", 
    RowBox[{"Geometry", ":", " ", 
     RowBox[{"Cardioid", " ", "Billiard"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"X", " ", 
     RowBox[{"range", ":", " ", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "4"}], "R"}], ",", " ", "R"}], "]"}]}]}], ",", " ", 
    RowBox[{"Y", " ", 
     RowBox[{"range", ":", " ", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "3"}], "R"}], ",", " ", 
        RowBox[{"3", "R"}]}], "]"}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"radiusR", " ", "=", " ", "15"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gridData", " ", "=", " ", 
     RowBox[{"GenerateCardioidBasis", "[", "radiusR", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dimSpace", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coords", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Coords\>\"", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"2.", " ", 
     RowBox[{"Operators", ":", " ", 
      RowBox[{
      "4", "D", " ", "Shift", " ", "and", " ", "Global", " ", "Grover", " ", 
       "Coin"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"shiftOp", " ", "=", " ", 
     RowBox[{"BuildShiftOperators", "[", 
      RowBox[{"gridData", ",", " ", 
       RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coinOp", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"dimSpace", ",", " ", "SparseArray"}], "]"}], ",", " ", "\n", 
       "    ", 
       RowBox[{"GeneralizedGroverCoin", "[", 
        RowBox[{"Pi", "/", "4"}], "]"}]}], "\n", "]"}]}], ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Calculate", " ", "the", " ", "unitary", " ", "step", " ", "for", " ", 
     "the", " ", "full", " ", "space"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"unitaryStepFull", " ", "=", " ", 
     RowBox[{"Chop", "[", 
      RowBox[{"shiftOp", " ", ".", " ", "coinOp"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"3.", " ", "Symmetry", " ", "Reduction", " ", 
     RowBox[{"(", 
      RowBox[{"Even", " ", 
       RowBox[{"Parity", " ", "/", " ", "Cs"}], " ", "Symmetry"}], ")"}]}], 
    " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "The", " ", "cardioid", " ", "is", " ", "only", " ", "symmetric", " ", 
      "across", " ", "the", " ", "X"}], "-", 
     RowBox[{"axis", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"y", " ", "->", " ", 
         RowBox[{"-", "y"}]}], ")"}], ".", " ", "We"}], " ", "project", " ", 
      "to", " ", "the", " ", "\"\<Even\>\"", " ", "subspace"}]}], " ", "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"isometryV", " ", "=", " ", 
     RowBox[{"BuildSymmetryIsometry", "[", 
      RowBox[{"gridData", ",", " ", "\"\<Even\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"unitaryRed", " ", "=", " ", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "isometryV", "]"}], " ", ".", " ", 
       "unitaryStepFull", " ", ".", " ", "isometryV"}], "]"}]}], ";"}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.981482991397875*^9, 3.9814830082547407`*^9}, {
   3.9814830662144117`*^9, 3.9814830821655617`*^9}, 3.9814841515045033`*^9, {
   3.981484306578022*^9, 3.981484331653248*^9}},
 CellLabel->
  "In[642]:=",ExpressionUUID->"a1f173f0-e354-489f-b74e-8b1f9c8206d9"],

