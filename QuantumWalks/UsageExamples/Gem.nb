Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"2.", " ", 
    RowBox[{"Operators", ":", " ", 
     RowBox[{
     "4", "D", " ", "Shift", " ", "and", " ", "Global", " ", "Grover", " ", 
      "Coin"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Constructing", " ", "the", " ", "4"}], "-", 
    RowBox[{
    "state", " ", "shift", " ", "operator", " ", "and", " ", "the", " ", 
     "tensor"}], "-", 
    RowBox[{"product", " ", "coin"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"shiftOp", " ", "=", " ", 
     RowBox[{"BuildShiftOperators", "[", 
      RowBox[{"gridData", ",", " ", 
       RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coinOp", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"dimSpace", ",", " ", "SparseArray"}], "]"}], ",", " ", "\n", 
       "    ", 
       RowBox[{"GeneralizedGroverCoin", "[", 
        RowBox[{"Pi", "/", "4"}], "]"}]}], "\n", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"unitaryStep", " ", "=", " ", 
     RowBox[{"shiftOp", " ", ".", " ", "coinOp"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{3.981476137274641*^9},
 CellLabel->
  "In[225]:=",ExpressionUUID->"c2c6edf3-4520-4fb4-aedb-19da349f999a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"3.", " ", "Symmetry", " ", 
    RowBox[{"Reduction", ":", " ", 
     RowBox[{"Even", "-", 
      RowBox[{"Even", " ", "Sector", " ", 
       RowBox[{"(", "A1", ")"}]}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Projecting", " ", "the", " ", "full", " ", "unitary", " ", "onto", " ", 
    "the", " ", "C2v", " ", "A1", " ", "subspace", " ", "to", " ", "reduce", " ",
     "dimensionality"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"isometryV", " ", "=", " ", 
     RowBox[{"BuildSymmetryIsometry", "[", 
      RowBox[{"gridData", ",", " ", "\"\<A1\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"unitaryRed", " ", "=", " ", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "isometryV", "]"}], " ", ".", " ", 
       "unitaryStep", " ", ".", " ", "isometryV"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{3.981476139266263*^9},
 CellLabel->
  "In[228]:=",ExpressionUUID->"faa7b6b2-7bfd-4beb-8430-732aa6098d50"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"4.", " ", "State", " ", "Initialization", " ", 
    RowBox[{"(", 
     RowBox[{
     "Localized", " ", "in", " ", "the", " ", "reduced", " ", "space"}], 
     ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dimRed", " ", "=", " ", 
     RowBox[{
      RowBox[{"Dimensions", "[", "unitaryRed", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialStateRed", " ", "=", " ", 
     RowBox[{"SparseArray", "[", 
      RowBox[{
       RowBox[{"{", 
