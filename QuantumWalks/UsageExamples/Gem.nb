        RowBox[{"#", ",", "dimSpace"}], "]"}], "&"}], "/@", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}]}]}], ";"}], "\n", 
   RowBox[{"unitaryStep", " ", "=", " ", 
    RowBox[{"Sx", ".", "coinB", ".", "Sy", ".", "coinA"}]}]}]}]], "Input",
