Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"3.", " ", "State", " ", "Initialization", " ", 
    RowBox[{"(", 
     RowBox[{
     "Localized", " ", "in", " ", "the", " ", "reduced", " ", "space"}], 
     ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"initialStateRed", " ", "=", " ", 
    RowBox[{"SparseArray", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"2", "*", 
          RowBox[{
           RowBox[{"gridData", "[", "\"\<Mapping\>\"", "]"}], "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "-", "1"}], "->", "1."}],
        "}"}], ",", 
      RowBox[{"2", "*", "dimSpace"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.98147614365796*^9, 3.9814761438331738`*^9}, {
  3.9815430182994823`*^9, 3.981543018386582*^9}, {3.981543088973649*^9, 
  3.98154313949168*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"d1b55207-112d-47ed-9c20-c1049e5b6da8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"4.", " ", "Time", " ", "Evolution", " ", 
    RowBox[{"(", 
     RowBox[{"t", " ", "=", " ", 
      RowBox[{"0", " ", "to", " ", "10"}]}], ")"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tMax", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"evolutionFull", " ", "=", " ", 
     RowBox[{"NestList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"unitaryStep", " ", ".", " ", "#"}], " ", "&"}], ",", " ", 
       "initialStateRed", ",", " ", "tMax"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "raw", " ", "spatial", " ", "coordinates", " ", "for", " ",
      "the", " ", "plotting", " ", "function"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coords", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Coords\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dimSpace", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "spatial", " ", "probabilities", " ", "by", " ", 
     "tracing", " ", "out", " ", "the", " ", "4", " ", "internal", " ", 
     "coin", " ", "states"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"probabilityDistributions", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"stateFull", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{
              RowBox[{"2", "*", 
               RowBox[{"(", 
                RowBox[{"i", "-", "1"}], ")"}]}], "+", "1"}], " ", ";;", " ", 
             
             RowBox[{"2", "*", "i"}]}], "]"}], "]"}], "]"}], "^", "2"}], 
        "]"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"stateFull", ",", " ", "evolutionFull"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "1", ",", " ", "dimSpace"}], "}"}]}], "\n", 
      "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{
  3.981476148649803*^9, {3.981476929241714*^9, 3.981476940729438*^9}, {
   3.981477330233341*^9, 3.981477331489305*^9}, {3.981477503258363*^9, 
   3.981477504177267*^9}, {3.981477602522296*^9, 3.981477602744907*^9}, {
