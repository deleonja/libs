Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Define", " ", "Gaussian", " ", "parameters"}], " ", 
   "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "You", " ", "can", " ", "manually", " ", "set", " ", "centerCoord", " ", 
    "to", " ", "any", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], " ", "valid", " ", "for", " ", "your", " ",
     "chosen", " ", "geometry"}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"For", " ", "the", " ", 
      RowBox[{"rectangle", ":", " ", "centerCoord"}]}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Round", "[", 
        RowBox[{"widthLx", " ", "/", " ", "2"}], "]"}], ",", " ", 
       RowBox[{"Round", "[", 
        RowBox[{"heightLy", " ", "/", " ", "2"}], "]"}]}], "}"}]}], ";"}], 
   " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"For", " ", "the", " ", 
      RowBox[{"cardioid", ":", " ", "centerCoord"}]}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "radiusR"}], ",", " ", "0"}], "}"}]}], ";"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sigma", " ", "=", " ", "1."}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Standard", " ", 
     RowBox[{"deviation", " ", "/", " ", "spread"}], " ", "of", " ", "the", " ",
      "wavepacket"}], " ", "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"2.", " ", "Calculate", " ", "spatial", " ", "amplitudes"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Amplitude", " ", "decays", " ", "as", " ", 
