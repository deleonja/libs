Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"5.", " ", "Time", " ", "Evolution", " ", 
    RowBox[{"(", 
     RowBox[{"t", " ", "=", " ", 
      RowBox[{"0", " ", "to", " ", "10"}]}], ")"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tMax", "=", "1000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"evolutionRed", " ", "=", " ", 
     RowBox[{"NestList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"unitaryRed", " ", ".", " ", "#"}], " ", "&"}], ",", " ", 
       "initialStateRed", ",", " ", "tMax"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Project", " ", "the", " ", "A1", " ", "evolution", " ", "back", " ", 
     "into", " ", "the", " ", "full", " ", "dimensional", " ", "Hilbert", " ",
      "space"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evolutionFull", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"isometryV", " ", ".", " ", "#"}], " ", "&"}], " ", "/@", " ", 
      "evolutionRed"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "raw", " ", "spatial", " ", "coordinates", " ", "for", " ",
      "the", " ", "plotting", " ", "function"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"coords", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Coords\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dimSpace", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "spatial", " ", "probabilities", " ", "by", " ", 
     "tracing", " ", "out", " ", "the", " ", "4", " ", "internal", " ", 
     "coin", " ", "states"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"probabilityDistributions", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"stateFull", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{
              RowBox[{"4", "*", 
               RowBox[{"(", 
                RowBox[{"i", "-", "1"}], ")"}]}], "+", "1"}], " ", ";;", " ", 
             
             RowBox[{"4", "*", "i"}]}], "]"}], "]"}], "]"}], "^", "2"}], 
        "]"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"stateFull", ",", " ", "evolutionFull"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "1", ",", " ", "dimSpace"}], "}"}]}], "\n", 
      "]"}]}], ";"}]}]}]], "Input",
