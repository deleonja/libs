Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Define", " ", 
    RowBox[{"Geometry", ":", " ", 
     RowBox[{"Full", " ", "Bunimovich", " ", "Stadium"}]}]}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"radiusR", " ", "=", " ", "15"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lengthL", " ", "=", " ", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gridData", " ", "=", " ", 
     RowBox[{"GenerateFullStadiumBasis", "[", 
      RowBox[{"lengthL", ",", " ", "radiusR"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dimSpace", " ", "=", " ", 
     RowBox[{"gridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "coordinates", " ", "and", " ", "plot", " ", "the", " ", 
     "spatial", " ", "grid"}], " ", "*)"}], "\n", 
   RowBox[{"stadiumPlot", " ", "=", " ", 
    RowBox[{"ListPlot", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"gridData", "[", "\"\<Coords\>\"", "]"}], ",", "\n", "    ", 
      RowBox[{"AspectRatio", " ", "->", " ", "Automatic"}], ",", "\n", "    ", 
      RowBox[{"PlotStyle", " ", "->", " ", 
       RowBox[{"Directive", "[", 
        RowBox[{
         RowBox[{"PointSize", "[", "0.015", "]"}], ",", " ", 
         RowBox[{"Darker", "[", "Cyan", "]"}]}], "]"}]}], ",", "\n", "    ", 
      RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "    ", 
      RowBox[{"Axes", " ", "->", " ", "False"}], ",", "\[IndentingNewLine]", 
      RowBox[{"LabelStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", "23"}], "]"}]}], ",", "\n", "    ", 
      RowBox[{"ImageSize", "->", "700"}]}], "\n", "]"}]}]}]}]], "Input",
