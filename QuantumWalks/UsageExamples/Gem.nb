Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"2.", " ", 
    RowBox[{"Operators", ":", " ", 
     RowBox[{
     "4", "D", " ", "Shift", " ", "and", " ", "Global", " ", "Grover", " ", 
      "Coin"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Constructing", " ", "the", " ", "4"}], "-", 
    RowBox[{
    "state", " ", "shift", " ", "operator", " ", "and", " ", "the", " ", 
     "tensor"}], "-", 
    RowBox[{"product", " ", "coin"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Sx", ",", "Sy"}], "}"}], " ", "=", " ", 
     RowBox[{"BuildShiftOperators", "[", "gridData", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Pi", "/", "4."}], ",", 
       RowBox[{"Pi", "/", "3."}]}], "}"}]}], ";", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"coinA", ",", "coinB"}], "}"}], "=", 
