Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"5.", " ", "Animation", " ", "Generation", " ", "Setup", " ", 
    RowBox[{"(", 
     RowBox[{"Modified", " ", "for", " ", "Full", " ", "Stadium"}], ")"}]}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"maxProb", " ", "=", " ", 
     RowBox[{"Max", "[", "probabilityDistributions", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"probMin", " ", "=", " ", 
     RowBox[{"2", "*", 
      RowBox[{"10.", "^", 
       RowBox[{"-", "10"}]}]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Threshold", " ", "to", " ", "avoid", " ", 
     RowBox[{"Log", "[", "0", "]"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"logPMin", " ", "=", " ", 
     RowBox[{"Log10", "[", "probMin", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logPMax", " ", "=", " ", 
     RowBox[{"Log10", "[", "maxProb", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
