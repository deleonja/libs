Cell[CellGroupData[{

Cell[TextData[StyleBox["CTQWHamiltonian[gridData, gamma, connectionVectors]", \
"Code"]], "Section",
 CellChangeTimes->{{3.981047643189728*^9, 
  3.981047644421792*^9}},ExpressionUUID->"e521b933-79bb-4c00-a8a9-\
2077fad85dfb"],

Cell["\<\
constructs the continuous-time quantum walk (CTQW) Hamiltonian H = -\[Gamma] \
L, where L = D - A is the graph Laplacian (D being the degree diagonal matrix \
and A the adjacency matrix).\
\>", "Text",
 CellChangeTimes->{
  3.981047172926968*^9},ExpressionUUID->"648e766c-d122-4e7f-9458-\
60c7c77c0c1c"],

Cell["It takes the following arguments:", "Text",ExpressionUUID->"ec9d657c-470e-4998-8455-7364a59f2d1e"],

Cell[TextData[{
 StyleBox["gridData", "Input",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " defining the geometry."
}], "Item",ExpressionUUID->"5824053d-6b10-4d10-bc08-3bfee4f22458"],

Cell[TextData[{
 StyleBox["gamma", "Input",
  FontWeight->"Bold"],
 ": (Optional) The hopping factor \[Gamma]. Defaults to 1.0."
}], "Item",ExpressionUUID->"41fef864-8acf-4a82-9802-9abc6ff96353"],

Cell[TextData[{
 StyleBox["connectionVectors", "Input",
  FontWeight->"Bold"],
 ": (Optional) A list of jump vectors. Defaults to nearest neighbors: {{1, \
0}, {-1, 0}, {0, 1}, {0, -1}}."
}], "Item",
 CellChangeTimes->{{3.981047222735663*^9, 
  3.9810472267592077`*^9}},ExpressionUUID->"4f7b2a89-28da-453b-bc12-\
42b0318bbaf2"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",ExpressionUUID->"4360e142-5054-4d5d-a3d9-505f894acdae"],

Cell["\<\
Construct the Hamiltonian for the previous grid with a hopping factor of 0.5:\
\
\>", "Text",ExpressionUUID->"449de712-3f6d-4a16-8b1c-63dbb489f9bb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"grid", "=", 
   RowBox[{"GenerateRectangleBasis", "[", 
    RowBox[{"2", ",", "2"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"H", "=", 
  RowBox[{"CTQWHamiltonian", "[", 
   RowBox[{"grid", ",", "0.5"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.981047233288813*^9, 3.98104725938478*^9}},
 CellLabel->
  "In[139]:=",ExpressionUUID->"1e6714cf-5d38-4b60-8c3e-be3b513eff30"],

