Cell[CellGroupData[{

Cell["Routines\[CloseCurlyQuote] details and usage examples", "Chapter",
 CellChangeTimes->{{3.981031302893216*^9, 
  3.981031338420267*^9}},ExpressionUUID->"90979d07-891f-4399-b25c-\
3ed890bf7594"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["BuildAdjacencyMatrix[gridData, connectionVectors]", \
"Code"]], "Section",
 CellChangeTimes->{{3.9810470479601707`*^9, 
  3.9810470486962023`*^9}},ExpressionUUID->"e82c54ae-3e54-44c3-895b-\
68bc0acd7021"],

Cell["\<\
constructs the adjacency matrix of the graph defined by the grid geometry \
using an O(1) lookup search. This matrix dictates the allowed transitions \
between nodes.\
\>", "Text",
 CellChangeTimes->{{3.98104707356816*^9, 
  3.9810470745681562`*^9}},ExpressionUUID->"61d46f6d-2d3d-4c2f-883a-\
fd5320dc2bd6"],

Cell["It takes the following arguments:", "Text",ExpressionUUID->"738c1dea-547e-4f9e-ad36-4dc2841c5c20"],

Cell[TextData[{
 StyleBox["gridData", "Input",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing the coordinate basis and mapping (e.g., generated by ",
 StyleBox[ButtonBox["GenerateRectangleBasis",
  BaseStyle->"Hyperlink",
  ButtonData->{
    FrontEnd`FileName[{$RootDirectory, "home", "jadeleon", "Documents", 
      "libs", "QuantumWalks", "UsageExamples"}, "Billiards.nb", 
     CharacterEncoding -> "UTF-8"], "GenerateRectangleBasis"},
  ButtonNote->
   "/home/jadeleon/Documents/libs/QuantumWalks/UsageExamples/Billiards.nb"], 
  "Input"],
 ")."
}], "Item",
 CellChangeTimes->{{3.981047128321207*^9, 3.981047128322541*^9}, {
  3.981047363546826*^9, 
  3.981047363548059*^9}},ExpressionUUID->"f48945df-3c70-4822-91de-\
f84fd5af962b"],

Cell[TextData[{
 StyleBox["connectionVectors", "Input",
  FontWeight->"Bold"],
 ": (Optional) A list of vectors defining the allowed jumps. By default, it \
assumes nearest neighbors in a 2D square lattice: {{1, 0}, {-1, 0}, {0, 1}, \
{0, -1}}."
}], "Item",ExpressionUUID->"5a7c997f-5e81-4f46-8724-5905a46fc78e"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",ExpressionUUID->"1deb9df3-8719-49cf-982f-6fe9b8c1a0b8"],

Cell["\<\
Build the adjacency matrix for a 3x3 rectangular grid (Lx=2, Ly=2):\
\>", "Text",ExpressionUUID->"9d5481c8-6101-49c9-9c49-97f3bc7b15e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"grid", "=", 
   RowBox[{"GenerateRectangleBasis", "[", 
    RowBox[{"2", ",", "2"}], "]"}]}], ";", 
  RowBox[{"adjMatrix", "=", 
   RowBox[{"BuildAdjacencyMatrix", "[", "grid", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[119]:=",ExpressionUUID->"0c45cafd-2bd1-4bbf-a06d-1ed39c0e3268"],

Cell["Visualize the adjacency matrix structure:", "Text",ExpressionUUID->"0fa6c011-0d1d-4c1e-bde2-f5a9499418fc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixPlot", "[", 
  RowBox[{"adjMatrix", ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Nodes\>\"", ",", "\"\<Nodes\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[120]:=",ExpressionUUID->"142d0e6a-1b9f-4fbf-a6b8-9256eebe6793"],

