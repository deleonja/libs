          QuantumWalks`DQWL`Private`omegaK, QuantumWalks`DQWL`Private`vgK, 
          QuantumWalks`DQWL`Private`nVectorK, 
          QuantumWalks`DQWL`Private`integrand, 
          QuantumWalks`DQWL`Private`sigmas}, QuantumWalks`DQWL`Private`sigmas = {
            PauliMatrix[1], 
            PauliMatrix[2], 
            PauliMatrix[3]}; QuantumWalks`DQWL`Private`s = DiagonalMatrix[{
             Exp[(-I) QuantumWalks`DQWL`Private`k], 
             Exp[I QuantumWalks`DQWL`Private`k]}]; 
         QuantumWalks`DQWL`Private`uk = 
          Dot[QuantumWalks`DQWL`Private`s, QuantumWalks`DQWL`Private`c2, 
            QuantumWalks`DQWL`Private`s, QuantumWalks`DQWL`Private`c1]; 
         QuantumWalks`DQWL`Private`trU = ComplexExpand[
            Re[
             Tr[QuantumWalks`DQWL`Private`uk]]]; 
         QuantumWalks`DQWL`Private`omegaK = 
          ArcCos[QuantumWalks`DQWL`Private`trU/2]; 
         QuantumWalks`DQWL`Private`vgK = 
          D[QuantumWalks`DQWL`Private`omegaK, QuantumWalks`DQWL`Private`k]; 
         QuantumWalks`DQWL`Private`nVectorK = 
          Table[(I/(2 Sin[QuantumWalks`DQWL`Private`omegaK])) Tr[
