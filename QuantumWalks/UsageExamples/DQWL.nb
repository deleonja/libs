           QuantumWalks`DQWL`Private`zVector; 
         QuantumWalks`DQWL`Private`term3 = 
          QuantumWalks`DQWL`Private`sinHalf QuantumWalks`DQWL`Private`cosHalf 
           Cross[QuantumWalks`DQWL`Private`zVector, 
             QuantumWalks`DQWL`Private`nVector]; 
