          QuantumWalks`DQWL`Private`zVector, 
          QuantumWalks`DQWL`Private`cosHalf, 
          QuantumWalks`DQWL`Private`sinHalf, 
          QuantumWalks`DQWL`Private`prefactorA, 
          QuantumWalks`DQWL`Private`term1, QuantumWalks`DQWL`Private`term2, 
          QuantumWalks`DQWL`Private`term3}, 
         QuantumWalks`DQWL`Private`nVector = {
           Sin[QuantumWalks`DQWL`Private`alpha] 
            Cos[QuantumWalks`DQWL`Private`phi], 
            Sin[QuantumWalks`DQWL`Private`alpha] 
            Sin[QuantumWalks`DQWL`Private`phi], 
            Cos[QuantumWalks`DQWL`Private`alpha]}; 
         QuantumWalks`DQWL`Private`zVector = {0, 0, 1}; 
         QuantumWalks`DQWL`Private`cosHalf = 
          Cos[QuantumWalks`DQWL`Private`theta/2]; 
         QuantumWalks`DQWL`Private`sinHalf = 
          Sin[QuantumWalks`DQWL`Private`theta/2]; 
         QuantumWalks`DQWL`Private`prefactorA = (1 - 
            QuantumWalks`DQWL`Private`sinHalf 
            Sin[QuantumWalks`DQWL`Private`alpha])/(
           QuantumWalks`DQWL`Private`cosHalf^2 + 
           QuantumWalks`DQWL`Private`sinHalf^2 
            Cos[QuantumWalks`DQWL`Private`alpha]^2); 
