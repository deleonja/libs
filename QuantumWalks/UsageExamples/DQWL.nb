\[CurlyTheta]\", \"TI\"]\), \!\(\*StyleBox[\"\[Phi]\", \"TI\"]\)} and angle \
of rotation \!\(\*StyleBox[\"\[Theta]\", \"TI\"]\).", "Documentation" -> None,
     "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
