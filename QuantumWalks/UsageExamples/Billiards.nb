Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"1.", " ", "Extraemos", " ", 
     RowBox[{"par\[CapitalATilde]\[DownExclamation]metros", ".", "En"}], " ", 
     
     RowBox[{"Bunimovich", ".", "wl"}]}], ",", 
    RowBox[{"\"\<Params\>\"", " ", "es", " ", "la", " ", "lista", " ", 
     RowBox[{"{", 
      RowBox[{"xc", ",", "nu"}], "}"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xcParameter", ",", "nuParameter"}], "}"}], "=", 
     RowBox[{"billiardData", "[", "\"\<Params\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Definimos", " ", "la", " ", "funci\[CapitalATilde]\.b3n", " ",
      "l\[CapitalATilde]\.b3gica", " ", "del", " ", "Estadio", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"1", "/", "4"}], " ", "Desimetrizado"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"StadiumRegionQ", "=", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"inRectangle", ",", "inCircle"}], "}"}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Condici\[CapitalATilde]\.b3n", " ", "1"}], ":", 
           RowBox[{"Parte", " ", "rectangular", " ", 
            RowBox[{"(", 
             RowBox[{"0", "<=", "x", "<=", "xc"}], ")"}]}]}], "*)"}], 
         RowBox[{
          RowBox[{"inRectangle", "=", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "<=", "xcParameter"}], "&&", 
             RowBox[{"y", "<=", "nuParameter"}]}], ")"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Condici\[CapitalATilde]\.b3n", " ", "2"}], ":", 
            RowBox[{"Parte", " ", "circular", " ", 
             RowBox[{"(", 
              RowBox[{"x", ">", "xc"}], ")"}]}]}], "*)"}], 
          RowBox[{"(*", 
           RowBox[{"Centrada", " ", "en", " ", 
            RowBox[{"(", 
             RowBox[{"xc", ",", "0"}], ")"}], " ", "con", " ", "radio", " ", 
            "nu"}], "*)"}], 
          RowBox[{"inCircle", "=", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", ">", "xcParameter"}], "&&", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", "-", "xcParameter"}], ")"}], "^", "2"}], "+", 
               RowBox[{"y", "^", "2"}]}], "<=", 
              RowBox[{"nuParameter", "^", "2"}]}]}], ")"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
            "La", " ", "regi\[CapitalATilde]\.b3n", " ", 
             "v\[CapitalATilde]\[DownExclamation]lida", " ", "es", " ", "la", 
             " ", "uni\[CapitalATilde]\.b3n", " ", "de", " ", "ambas"}], ",", 
            
            RowBox[{
            "restringida", " ", "al", " ", "primer", " ", "cuadrante"}]}], 
           "*)"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"inRectangle", "||", "inCircle"}], ")"}], "&&", 
           RowBox[{"(", 
            RowBox[{"x", ">=", "0"}], ")"}], "&&", 
           RowBox[{"(", 
            RowBox[{"y", ">=", "0"}], ")"}]}]}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Generamos", " ", "el", " ", "Plot"}], "*)"}], "\n", 
   RowBox[{"ListDensityPlot", "[", 
    RowBox[{
     RowBox[{"StateToPlotData", "[", 
      RowBox[{
       RowBox[{"evecs", "[", 
        RowBox[{"[", "4201", "]"}], "]"}], ",", 
       RowBox[{"billiardData", "[", "\"\<Coords\>\"", "]"}]}], "]"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<BlueGreenYellow\>\""}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
     RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
     RowBox[{"InterpolationOrder", "->", "0"}], ",", 
     RowBox[{"(*", 
