Cell[CellGroupData[{

Cell["Neat examples", "Chapter",
 CellChangeTimes->{{3.981039039902512*^9, 
  3.981039063688209*^9}},ExpressionUUID->"575f3b7a-b802-4b71-b6c5-\
3659c74f7aa1"],

Cell[CellGroupData[{

Cell["\|01f3b1 Quantum Walks in Billiards: A Beginner\[CloseCurlyQuote]s \
Guide", "Section",
 CellChangeTimes->{
  3.9781004339161177`*^9},ExpressionUUID->"6c126b93-aa6d-43c5-b552-\
4ff7cea94474"],

Cell["\<\
We will simulate a Discrete-Time Quantum Walk (DTQW) inside a 2D billiard \
geometry. If you are familiar with a particle in a box from quantum \
mechanics, imagine that particle moving on a discrete grid, carrying an \
internal \[OpenCurlyDoubleQuote]coin\[CloseCurlyDoubleQuote] (spin) that \
tells it which way to turn.\
\>", "Text",
 CellChangeTimes->{
  3.9781004533425703`*^9, {3.978100859593211*^9, 3.9781008848324013`*^9}, {
   3.981039242159498*^9, 
   3.981039246331786*^9}},ExpressionUUID->"2d265196-551e-43be-bee1-\
90072fbca624"],

Cell[CellGroupData[{

Cell["1. Define the geometry", "Subsection",
 CellChangeTimes->{
  3.978100526739357*^9, {3.978199158000568*^9, 3.978199158696385*^9}, {
   3.981039253981125*^9, 3.9810392540634403`*^9}, {3.9810392873231983`*^9, 
   3.9810392908777657`*^9}},ExpressionUUID->"2ae9c6d4-f2be-4f77-895f-\
b264afd8558d"],

Cell["First, you must decide one of these geometries:", "Text",
 CellChangeTimes->{
  3.9781005341061172`*^9, {3.978100921368888*^9, 3.978100956034226*^9}, {
   3.9781991753695173`*^9, 3.978199202920405*^9}, 
   3.9810392607513723`*^9},ExpressionUUID->"8e0f0723-5652-4937-bb18-\
a959c6d82de7"],

Cell["Rectangle (integrable)", "Item",
 CellChangeTimes->{{3.978199217672666*^9, 
  3.9781992228718023`*^9}},ExpressionUUID->"564d4989-35ae-497e-b36f-\
a7cacaceb7ca"],

Cell["Ellipse (integrable) ", "Item",
 CellChangeTimes->{{3.978199217672666*^9, 
  3.978199228904028*^9}},ExpressionUUID->"210f2dd2-d979-43c1-bc60-\
acf1cae35d0a"],

Cell["\<\
Bunimovich (chaotic), you may choose to work in the dessymetrized or full \
stadium\
\>", "Item",
 CellChangeTimes->{{3.978199217672666*^9, 
  3.978199269528347*^9}},ExpressionUUID->"982cd550-01de-47b7-9ce8-\
71473ba277e3"],

Cell["\<\
Sinai (chaotic), you may choose to work in the dessymetrized or full billiard\
\
\>", "Item",
 CellChangeTimes->{{3.978199217672666*^9, 
  3.978199289730486*^9}},ExpressionUUID->"6afe2934-67f8-49f4-9a04-\
b351dce071be"],

Cell["Cardiod (chaotic), only full billiard available for now", "Item",
 CellChangeTimes->{{3.978199217672666*^9, 3.978199296864595*^9}, {
  3.978199357528923*^9, 
  3.978199371320135*^9}},ExpressionUUID->"f8486a58-2da5-4f39-986f-\
6848577c770a"],

Cell["\<\
Let us choose the Bunimovich dessymetrized billiard. First we must generate \
the basis for the position grid space:\
\>", "Text",
 CellChangeTimes->{{3.9781993864481153`*^9, 
  3.978199435756806*^9}},ExpressionUUID->"cbae6c9f-d77b-445c-baf5-\
bacde7f8d4ca"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "GenerateFullStadiumBasis"}]], "Input",
 CellChangeTimes->{{3.978463311763679*^9, 3.9784633151240063`*^9}, {
  3.978466415478154*^9, 3.978466416449951*^9}, {3.978788213506382*^9, 
  3.978788215900847*^9}, {3.979039509041003*^9, 3.979039512551053*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"49f62236-c002-4a0f-80de-17a405746a6f"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"GenerateFullStadiumBasis[L, R] genera la base de \
coordenadas y la asociaci\[OAcute]n de mapeo para el billar de estadio \
completo (Full Stadium). L: Semilongitud de la parte recta. R: Radio de los \
semic\[IAcute]rculos.\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"GenerateFullStadiumBasis", "[", 
                    
                    RowBox[{
                    "L_Integer", ",", 
                    "QuantumWalks`Billiards`Bunimovich`Private`R_Integer"}], 
                    "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{
                    "QuantumWalks`Billiards`Bunimovich`Private`coords", ",", 
                    "QuantumWalks`Billiards`Bunimovich`Private`stateToIndex", 
                    ",", "QuantumWalks`Billiards`Bunimovich`Private`\
validRegionQ"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{
                    "QuantumWalks`Billiards`Bunimovich`Private`validRegionQ", 
                    "=", 
                    RowBox[{"Function", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`x", 
                    ",", "QuantumWalks`Billiards`Bunimovich`Private`y"}], 
                    "}"}], ",", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`dx", 
                    "=", 
                    
                    RowBox[{"Abs", "[", 
                    "QuantumWalks`Billiards`Bunimovich`Private`x", "]"}]}], 
                    ",", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`dy", 
                    "=", 
                    
                    RowBox[{"Abs", "[", 
                    "QuantumWalks`Billiards`Bunimovich`Private`y", "]"}]}]}], 
                    "}"}], ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`dx", 
                    "\[LessEqual]", "L"}], ",", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`dy", 
                    "\[LessEqual]", 
                    "QuantumWalks`Billiards`Bunimovich`Private`R"}], ",", 
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`dx", 
                    "\[LessEqual]", 
                    RowBox[{"L", "+", 
                    RowBox[{"Round", "[", 
                    SqrtBox[
                    RowBox[{"Max", "[", 
                    RowBox[{"0", ",", 
                    RowBox[{
                    SuperscriptBox[
                    "QuantumWalks`Billiards`Bunimovich`Private`R", "2"], "-", 
                    
                    SuperscriptBox[
                    "QuantumWalks`Billiards`Bunimovich`Private`dy", "2"]}]}], 
                    "]"}]], "]"}]}]}]}], "]"}]}], "]"}]}], "]"}]}], ";", 
                    
                    RowBox[{
                    "QuantumWalks`Billiards`Bunimovich`Private`coords", "=", 
                    RowBox[{"Select", "[", 
                    RowBox[{
                    RowBox[{"Flatten", "[", 
                    RowBox[{
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`x", 
                    ",", "QuantumWalks`Billiards`Bunimovich`Private`y"}], 
                    "}"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`x", 
                    ",", 
                    RowBox[{
                    RowBox[{"-", "L"}], "-", 
                    "QuantumWalks`Billiards`Bunimovich`Private`R"}], ",", 
                    
                    RowBox[{"L", "+", 
                    "QuantumWalks`Billiards`Bunimovich`Private`R"}]}], "}"}], 
                    ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"QuantumWalks`Billiards`Bunimovich`Private`y", 
                    ",", 
                    RowBox[{
                    "-", "QuantumWalks`Billiards`Bunimovich`Private`R"}], ",",
                     "QuantumWalks`Billiards`Bunimovich`Private`R"}], "}"}]}],
                     "]"}], ",", "1"}], "]"}], ",", 
                    
                    RowBox[{"Apply", "[", 
                    "QuantumWalks`Billiards`Bunimovich`Private`validRegionQ", 
                    "]"}]}], "]"}]}], ";", 
                    
                    RowBox[{
                    "QuantumWalks`Billiards`Bunimovich`Private`stateToIndex", 
                    "=", 
