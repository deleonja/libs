Cell["\<\
Compare the dimensions of the full Hilbert space (4 internal states per node) \
vs. the reduced symmetric subspace:\
\>", "Text",ExpressionUUID->"13fa83c5-8b02-4c90-92ff-0d7af970f0de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"FullDim", "=", 
    RowBox[{"4", " ", 
     RowBox[{"grid", "[", "\"\<Dimension\>\"", "]"}]}]}], ",", 
   RowBox[{"ReducedDim", "=", 
    RowBox[{"Last", "[", 
     RowBox[{"Dimensions", "[", "isometryA1", "]"}], "]"}]}]}], 
  "}"}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"0ba86884-2c0d-4b77-9f61-a6829da10bc3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"12388", ",", "3160"}], "}"}]], "Output",
 CellChangeTimes->{3.981045980320449*^9, 3.98104605636342*^9, 
  3.9810462491018457`*^9},
 CellLabel->"Out[90]=",ExpressionUUID->"e8290209-00d4-4ebc-8db0-5a53102126dd"]
}, Closed]],

Cell[TextData[{
 "Verify that the isometry is semi-unitary ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SuperscriptBox["V", "\[Dagger]"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "33f3fd3f-f0ee-4822-a22f-259296172d05"],
 "V = I):"
}], "Text",
 CellChangeTimes->{{3.981046265556731*^9, 
  3.981046268698271*^9}},ExpressionUUID->"4c2d6fdd-a24f-4f59-ab0f-\
0c9dd3e88520"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Chop", "[", 
   RowBox[{
    TemplateBox[{"isometryA1"},
     "ConjugateTranspose"], ".", "isometryA1"}], "]"}], "\[Equal]", 
  RowBox[{"IdentityMatrix", "[", "ReducedDim", "]"}]}]], "Input",
