Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateRectangleBasis[Lx,Ly]", "Code"]], "Section",
 FontColor->RGBColor[0.85, 0.39, 0.14],
 CellTags->
  "GenerateRectangleBasis",ExpressionUUID->"e61054c8-faab-45eb-a29e-\
eee234fca8be"],

Cell["\<\
The function generates the coordinate basis and mapping for a rectangular \
billiard (integrable system). It selects integer points (x,y) that satisfy \
the rectangular geometry constraints 0 \[LessEqual] x \[LessEqual] Lx and 0 \
\[LessEqual] y \[LessEqual] Ly[cite: 206, 207, 208].\
\>", "Text",
 CellTags->
  "GenerateRectangleBasis",ExpressionUUID->"a97069b5-cfee-432a-9a94-\
820c344f3f0b"],

Cell[TextData[{
 "For the rectangular billiard with width ",
 StyleBox["Lx",
  FontWeight->"Bold"],
 " and height ",
 StyleBox["Ly",
  FontWeight->"Bold"],
 ", it returns an ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object with the following keys:"
}], "Text",ExpressionUUID->"636204de-71ec-4f9d-a0d8-bb05f58ce1e6"],

Cell[TextData[{
 StyleBox["\"Coords\"",
  FontWeight->"Bold"],
 ": A flat list with all valid spatial coordinates {x,y} that form the basis \
of the position Hilbert subspace."
}], "Item",ExpressionUUID->"0e572238-6b18-4613-9e57-4f409e0de6e5"],

Cell[TextData[{
 StyleBox["\"Mapping\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object that acts as a dictionary. It allows entering a coordinate (e.g., \
{0,0}) and obtaining its corresponding matrix index in O(1) time[cite: 208, \
209]."
}], "Item",ExpressionUUID->"b8d04dbd-93d1-49e3-83cf-7b00472d1b73"],

Cell[TextData[{
 StyleBox["\"Dimension\"",
  FontWeight->"Bold"],
 ": An integer indicating the total dimension of the spatial basis."
}], "Item",ExpressionUUID->"026a288a-7023-4197-841b-c1e4921038ae"],

Cell[TextData[{
 StyleBox["\"Params\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing the original input parameters, saved as <|\"Lx\" \[Rule] Lx, \
\"Ly\" \[Rule] Ly|>."
}], "Item",ExpressionUUID->"ab358eab-7892-48d0-b8c0-ff76744bc712"],

Cell[TextData[{
 StyleBox["\"Type\"",
  FontWeight->"Bold"],
 ": The label \"Rectangle\" to easily identify the generated geometry."
}], "Item",ExpressionUUID->"9aa5e069-900a-49e9-bb76-b1ffd607d491"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"31d2bf24-c457-433f-9521-f1431d5e59d8"],

Cell[TextData[{
 "Coordinate basis and mapping for a rectangular billiard of width ",
 StyleBox["Lx=10",
  FontWeight->"Bold"],
 " and height ",
 StyleBox["Ly=5",
  FontWeight->"Bold"],
 ":"
}], "Text",ExpressionUUID->"4d768241-d619-45fa-be4f-ebecc7404183"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RectangleData", "=", 
   RowBox[{"GenerateRectangleBasis", "[", 
    RowBox[{"10", ",", "5"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"11afc6b5-5fef-4361-9282-2a94f4be7301"],

Cell["The grid of RectangleData:", "Text",ExpressionUUID->"da00f261-e941-4f21-87fa-74c7853b209c"],

