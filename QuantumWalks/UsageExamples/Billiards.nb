Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateSinaiBasis[L,R]", "Code"]], "Section",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"0341151e-05d2-442d-8a59-4ba7da306694"],

Cell["\<\
The function generates the coordinate basis and the mapping association for \
the fundamental domain (1/8) of the Sinai billiard. This domain is defined \
within a square of semi-side L, excluding a disk of radius R, and restricted \
by diagonal symmetry (0 \[LessEqual] y \[LessEqual] x).\
\>", "Text",
 CellChangeTimes->{
  3.9810447991032467`*^9},ExpressionUUID->"0668bfd4-497a-42d9-9ef0-\
2fb33425e8a7"],

Cell[TextData[{
 "For the fundamental domain with semi-side ",
 StyleBox["L",
  FontWeight->"Bold"],
 " and radius ",
 StyleBox["R",
  FontWeight->"Bold"],
 ", it returns an ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object with the following keys:"
}], "Text",
 CellChangeTimes->{
  3.98104480544772*^9},ExpressionUUID->"9b20e127-065c-486e-b04e-b3d430b213b1"],

Cell[TextData[{
 StyleBox["\"Coords\"",
  FontWeight->"Bold"],
 ": A flat list with all valid spatial coordinates {x, y} that form the basis \
of the 1/8 domain position subspace."
}], "Item",ExpressionUUID->"f38639f7-e591-4299-8071-a2ceeca44081"],

Cell[TextData[{
 StyleBox["\"Mapping\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object for O(1) coordinate-to-index lookups."
}], "Item",
 CellChangeTimes->{
  3.981044821655794*^9},ExpressionUUID->"02dc477e-620c-43c0-8779-\
b483985c10bd"],

Cell[TextData[{
 StyleBox["\"Dimension\"",
  FontWeight->"Bold"],
 ": An integer indicating the total number of points in the desymmetrized \
grid."
}], "Item",
 CellChangeTimes->{
  3.9810448181195803`*^9},ExpressionUUID->"e29d3d0f-ae43-448e-ae19-\
200466c3332b"],

Cell[TextData[{
 StyleBox["\"Params\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing the geometric parameters: <|\"L\" \[Rule] L, \"R\" \[Rule] R, \
\"Symmetry\" \[Rule] \"1/8\"|>."
}], "Item",
 CellChangeTimes->{{3.9810448091117573`*^9, 
  3.981044812175811*^9}},ExpressionUUID->"1d37a882-77a2-4578-873f-\
e6eb7ac75183"],

Cell[TextData[{
 StyleBox["\"Type\"",
  FontWeight->"Bold"],
 ": The label \"Sinai\" identifying the geometry."
}], "Item",
 CellChangeTimes->{
  3.981045117269696*^9},ExpressionUUID->"23b63d60-bce7-47aa-a76b-\
c92c71def856"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"c777635c-311a-4c0c-9727-132181521344"],

