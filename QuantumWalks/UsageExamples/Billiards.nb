Cell[TextData[{
 "A single time step ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "U", ")"}], TraditionalForm]],ExpressionUUID->
  "634544d3-2a2c-462b-9bb6-1d18d7a23151"],
 " in a 2D Split-Step Quantum Walk is often defined as: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Psi]", 
     RowBox[{"t", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["S", "x"], 
     SubscriptBox["C", "2"], 
     SubscriptBox["S", "y"], 
     SubscriptBox["C", "1"]}]}], TraditionalForm]],ExpressionUUID->
  "021adcd3-f831-4543-ac6c-26ab2525f5f4"]
}], "Text",
