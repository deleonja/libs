Cell[TextData[{
 "Generating the block-diagonal coin with a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    RowBox[{"\[Pi]", "/", "3"}]}], TraditionalForm]],ExpressionUUID->
  "7f292128-5ec1-4d08-bbb8-5dcf21f6d3da"],
 ":"
}], "Text",
