Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateBunimovichBasis[l,R]", "Code"]], "Section",
 CellChangeTimes->{
  3.981030573131091*^9, {3.981031236777588*^9, 
   3.9810312410210733`*^9}},ExpressionUUID->"f072d3f3-a073-436c-ae55-\
ab636d5c64b2"],

Cell[TextData[{
 "generates the coordinate basis and mapping for the desymmetrized (1/4) \
Bunimovich stadium using the boundary equations BoundaryX and BoundaryY. It \
selects integer points (m,n) that satisfy the stadium geometry constraints in \
the first quadrant.\n\nFor the desymmetrized Bunimovich billiard (reduced to \
1/4 of its original size using spatial symmetries) with semi-length ",
 StyleBox["l", "Input"],
 " and semi-circle radius ",
 StyleBox["R", "Input"],
 ", it returns an ",
 StyleBox["Association", "Input"],
 " object with the following keys:"
}], "Text",
 CellChangeTimes->{{3.981030579475617*^9, 3.981030610811921*^9}, {
  3.981031148650695*^9, 3.981031160771402*^9}, {3.98103119280237*^9, 
  3.98103121351991*^9}, {3.981031383057087*^9, 3.981031562402802*^9}, {
  3.981031765231379*^9, 3.9810318324012527`*^9}, {3.9810372901260147`*^9, 
  3.981037290358032*^9}},ExpressionUUID->"1949e49b-ced9-4c6c-9a1b-\
0ec4731a6d2c"],

Cell["\<\
\[OpenCurlyDoubleQuote]Coords\[CloseCurlyDoubleQuote]: A flat list with all \
valid spatial coordinates {x,y} that form the basis of the position Hilbert \
subspace.\
\>", "Item",
 CellChangeTimes->{{3.981030930490171*^9, 3.9810309788285*^9}, {
  3.981031835325515*^9, 
  3.981031842116287*^9}},ExpressionUUID->"62b304a9-1ce2-4eac-b6b7-\
974fb45a8bc7"],

Cell[TextData[{
 "\[OpenCurlyDoubleQuote]Mapping\[CloseCurlyDoubleQuote]: An ",
 StyleBox["Association", "Input"],
 " object that acts as a dictionary. It allows entering a coordinate (e.g., \
{0,0}) and obtaining its corresponding matrix index in O(1) time."
}], "Item",
 CellChangeTimes->{{3.981030930490171*^9, 3.9810309788285*^9}, {
  3.981031835325515*^9, 
  3.9810318454511147`*^9}},ExpressionUUID->"753035f8-f5bb-4512-89ed-\
d942e9c313cb"],

Cell["\<\
\[OpenCurlyDoubleQuote]Dimension\[CloseCurlyDoubleQuote]: An integer \
indicating the total dimension of the spatial basis.\
\>", "Item",
 CellChangeTimes->{{3.981030930490171*^9, 3.9810309788285*^9}, {
  3.981031835325515*^9, 
  3.9810318495790863`*^9}},ExpressionUUID->"9515dcc0-e8ad-404b-9ea2-\
6bb58bdfd70a"],

Cell[TextData[{
 "\[OpenCurlyDoubleQuote]Params\[CloseCurlyDoubleQuote]: A list with the \
original input parameters, saved as {semi-length ",
 StyleBox["l", "Input"],
 ", semi-circle radius ",
 StyleBox["R", "Input"],
 "}."
}], "Item",
 CellChangeTimes->{{3.981030930490171*^9, 3.9810309788285*^9}, {
  3.981031835325515*^9, 3.9810318526283484`*^9}, {3.981032088382419*^9, 
  3.981032095750393*^9}},ExpressionUUID->"e39b45d4-7c5e-435c-8db3-\
7968595db532"],

Cell["\<\
\[OpenCurlyDoubleQuote]Type\[CloseCurlyDoubleQuote]: The label \
\[OpenCurlyDoubleQuote]Bunimovich\[CloseCurlyDoubleQuote] to easily identify \
the generated geometry.\
\>", "Item",
 CellChangeTimes->{{3.981030930490171*^9, 3.9810309788285*^9}, {
  3.981031835325515*^9, 
  3.981031852086728*^9}},ExpressionUUID->"617afc47-c5f9-44f2-be7e-\
43c4dc6055c7"],

Cell[CellGroupData[{

Cell["Usage exmple", "Subsection",
 CellChangeTimes->{{3.981032215410521*^9, 
  3.981032217241993*^9}},ExpressionUUID->"d7264d74-bb99-45db-8c52-\
77037a8535fb"],

Cell[TextData[{
 "Coordinate basis and mapping for a desymmetrized Bunimovich stadium of \
semi-length ",
 StyleBox["l", "Input"],
 "=10 and semi-circle radius ",
 StyleBox["R", "Input"],
 "=15:"
}], "Text",
 CellChangeTimes->{{3.981032225793777*^9, 3.981032316509882*^9}, {
  3.9810329428427753`*^9, 
  3.981032943055717*^9}},ExpressionUUID->"dba42c0c-0821-4470-8981-\
66d10d2d8f2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BunimovichData", "=", 
   RowBox[{"GenerateBunimovichBasis", "[", 
    RowBox[{"10", ",", "15"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981032319318141*^9, 3.981032326231248*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"3dfe0b2c-9fe8-426d-92bb-31f4e8ab1d98"],

Cell[TextData[{
 "The grid of ",
 StyleBox["BunimovichData", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.98103244229731*^9, 
  3.981032450097186*^9}},ExpressionUUID->"020df26c-e86a-419c-905c-\
54276740322a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"BunimovichData", "[", "\"\<Coords\>\"", "]"}], ",", 
   RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"PointSize", "[", "0.02", "]"}], "]"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "20"}], "]"}]}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", " ", "\"\<y\>\""}], "}"}]}], ",", 
   RowBox[{"ImageSize", "->", "Large"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981032331635551*^9, 3.981032414165934*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"1bfc68ef-1fdd-4fb4-97cd-1f94bfdb6905"],

Cell[BoxData[
 GraphicsBox[{{}, 
   InterpretationBox[{
     TagBox[
      TagBox[
       {RGBColor[0.24, 0.6, 0.8], PointSize[0.02], AbsoluteThickness[2], 
        PointBox[CompressedData["
