Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Verify", " ", "unitarity"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"UnitaryMatrixQ", "[", "GroverCoin", "]"}], "\n", 
