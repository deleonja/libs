  3.9781995385365133`*^9}},ExpressionUUID->"2be8a1dd-3c3f-4f67-9352-\
2ff6412df496"],

Cell[TextData[{
 "The library function ",
 StyleBox["BuildShiftOperators", "Code"],
 " does the heavy lifting of handling boundary conditions (bouncing off \
walls) using Sparse Arrays to save memory."
}], "Text",
 CellChangeTimes->{{3.978101080113483*^9, 
  3.978101095277236*^9}},ExpressionUUID->"ae26bae0-20d9-4920-82e0-\
e0e27ea7c435"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Construct", " ", "Shift", " ", "Operators"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Returns", " ", "a", " ", "list", " ", 
    RowBox[{"{", 
     RowBox[{"Wm", ",", "Wn"}], "}"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Sx", ",", "Sy"}], "}"}], "=", 
     RowBox[{"BuildShiftOperators", "[", "billiardData", "]"}]}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Construct", " ", "the", " ", "Coin", " ", "Operator"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"We", " ", "use", " ", "a", " ", "standard", " ", "Hadamard"}], "-", 
     RowBox[{"like", " ", "coin", " ", "with", " ", "angle", " ", 
      RowBox[{"Pi", "/", "4"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dim", "=", 
     RowBox[{"billiardData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Coin1", "=", 
     RowBox[{"Coin", "[", 
      RowBox[{
       RowBox[{"Pi", "/", "4."}], ",", "dim"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Coin2", "=", 
     RowBox[{"Coin", "[", 
      RowBox[{
       RowBox[{"Pi", "+", "0.1"}], ",", "dim"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]1", ",", "\[Theta]2"}], "}"}], "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"2", "Pi"}]}], "}"}], ",", "2"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Coin1", "=", 
      RowBox[{"Coin", "[", 
       RowBox[{"\[Theta]1", ",", "dim"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Coin2", "=", 
      RowBox[{"Coin", "[", 
       RowBox[{"\[Theta]2", ",", "dim"}], "]"}]}], ";"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Check", " ", "if", " ", "the", " ", "operators", " ", "are", " ", 
     "Unitary", " ", 
     RowBox[{"(", 
      RowBox[{"Preserve", " ", "probability"}], ")"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"This", " ", "is", " ", "a", " ", "good", " ", "physics", " ", 
     RowBox[{"check", "!"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"unitaryCheck", "=", 
     RowBox[{
      RowBox[{"UnitaryMatrixQ", "[", "Sy", "]"}], "&&", 
      RowBox[{"UnitaryMatrixQ", "[", "Sx", "]"}], "&&", 
      RowBox[{"UnitaryMatrixQ", "[", "Coin1", "]"}], "&&", 
      RowBox[{"UnitaryMatrixQ", "[", "Coin2", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Are our operators valid unitary matrices? \>\"", ",", 
      "unitaryCheck"}], "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.978100573868857*^9, 3.978100580202829*^9}, {
