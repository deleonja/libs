90e2fe2f4477"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"BlockDiagonalCoin", "[", 
   RowBox[{"Pi", "/", "3"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.981036459472177*^9, 3.981036467206942*^9}, {
  3.981036707789013*^9, 3.981036714133009*^9}},
 CellLabel->
  "In[103]:=",ExpressionUUID->"ec77f8c9-aabb-4b54-8ce5-94df98edce23"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", "2"], 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["3"]}], "2"], "0", "0"},
     {
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["3"]}], "2"], 
      FractionBox["1", "2"], "0", "0"},
     {"0", "0", 
      FractionBox["1", "2"], 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["3"]}], "2"]},
     {"0", "0", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["3"]}], "2"], 
      FractionBox["1", "2"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {4, 4}, 0, {
     1, {{0, 2, 4, 6, 8}, {{1}, {2}, {1}, {2}, {3}, {4}, {3}, {4}}}, {
      Rational[1, 2], Complex[0, Rational[1, 2]] 3^Rational[1, 2], 
       Complex[0, Rational[1, 2]] 3^Rational[1, 2], Rational[1, 2], Rational[
       1, 2], Complex[0, Rational[1, 2]] 3^Rational[1, 2], 
       Complex[0, Rational[1, 2]] 3^Rational[1, 2], Rational[
       1, 2]}}]]]]], "Output",
 CellChangeTimes->{3.981036467747055*^9, 3.981036729634487*^9},
 CellLabel->
  "Out[103]//MatrixForm=",ExpressionUUID->"da7c333a-916e-4562-9014-\
ea0d7dd576d3"]
}, Closed]]
