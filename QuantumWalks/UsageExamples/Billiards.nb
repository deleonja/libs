Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateCardioidBasis[R]", "Code"]], "Section",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"ad0b9357-9edb-42a3-b1e6-5d0308c0dd2a"],

Cell["\<\
The function generates the coordinate basis for a cardioid billiard defined \
by the algebraic equation (x^2 + y^2 + 2Rx)^2 \[LessEqual] 4R^2(x^2 + y^2). \
The cusp is located at the origin (0,0) and the main body extends towards \
negative x values.\
\>", "Text",ExpressionUUID->"5aba528b-2c99-4fa2-8360-15d3ff350071"],

Cell[TextData[{
 "For the cardioid billiard with scale parameter ",
 StyleBox["R",
  FontWeight->"Bold"],
 ", it returns an ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object with the following keys:"
}], "Text",ExpressionUUID->"275645fb-c1d7-4d5d-9b98-3d777d009e23"],

Cell[TextData[{
 StyleBox["\"Coords\"",
  FontWeight->"Bold"],
 ": A flat list with all valid spatial coordinates {x, y} that form the basis \
of the cardioid position subspace."
}], "Item",ExpressionUUID->"e1dee222-79d0-4cc8-a262-80138e439b97"],

Cell[TextData[{
 StyleBox["\"Mapping\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object that acts as a dictionary for O(1) coordinate-to-index mapping."
}], "Item",ExpressionUUID->"c54e5943-a16e-4281-9785-da1c70ffbc6f"],

Cell[TextData[{
 StyleBox["\"Dimension\"",
  FontWeight->"Bold"],
 ": An integer indicating the total number of points in the grid."
}], "Item",ExpressionUUID->"29425e38-2679-4480-a66d-6257daf15b8c"],

Cell[TextData[{
 StyleBox["\"Params\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing the radius parameter: <|\"R\" \[Rule] R|>."
}], "Item",ExpressionUUID->"182a49b4-7c4d-4d2b-a2f3-bd6bcb6423f1"],

Cell[TextData[{
 StyleBox["\"Type\"",
  FontWeight->"Bold"],
 ": The label \"Cardioid\" to identify the geometry."
}], "Item",ExpressionUUID->"93fde922-4b69-4ce6-b3b3-d8d42bd3a82e"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"4031d275-5ea5-4618-90c1-d720db70414e"],

Cell[TextData[{
 "Coordinate basis for a Cardioid billiard with ",
 StyleBox["R=10",
  FontWeight->"Bold"],
 ":"
}], "Text",ExpressionUUID->"53a348d6-9956-4fd4-9b07-98e614c31830"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CardioidData", "=", 
   RowBox[{"GenerateCardioidBasis", "[", "10", "]"}]}], ";"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"1640c2b4-fac7-4614-b30a-7b61dc38bf60"],

Cell["The grid of CardioidData:", "Text",ExpressionUUID->"dc60d1f2-289d-40c7-979d-a9184b73db67"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"CardioidData", "[", "\"\<Coords\>\"", "]"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"PointSize", "[", "0.01`", "]"}], "]"}]}], ",", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
   RowBox[{"FrameStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "20"}], "]"}]}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]], "Input",
 CellLabel->"In[68]:=",ExpressionUUID->"b57ec10e-a4b7-4443-9510-3bfa44978fb7"],

