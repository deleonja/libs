    "GenerateFullStadiumBasis[L, R] genera la base de coordenadas y la \
asociaci\[OAcute]n de mapeo para el billar de estadio completo (Full \
Stadium). L: Semilongitud de la parte recta. R: Radio de los \
semic\[IAcute]rculos.", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QuantumWalks`GenerateFullStadiumBasis, {
      QuantumWalks`GenerateFullStadiumBasis[
         Pattern[QuantumWalks`L, 
          Blank[Integer]], 
         Pattern[QuantumWalks`Billiards`Bunimovich`Private`R, 
          Blank[Integer]]] :> 
       Module[{QuantumWalks`Billiards`Bunimovich`Private`coords, 
          QuantumWalks`Billiards`Bunimovich`Private`stateToIndex, 
          QuantumWalks`Billiards`Bunimovich`Private`validRegionQ}, 
         QuantumWalks`Billiards`Bunimovich`Private`validRegionQ = 
          Function[{
            QuantumWalks`Billiards`Bunimovich`Private`x, 
             QuantumWalks`Billiards`Bunimovich`Private`y}, 
            
            Module[{QuantumWalks`Billiards`Bunimovich`Private`dx = 
              Abs[QuantumWalks`Billiards`Bunimovich`Private`x], 
              QuantumWalks`Billiards`Bunimovich`Private`dy = 
              Abs[QuantumWalks`Billiards`Bunimovich`Private`y]}, 
             If[
             QuantumWalks`Billiards`Bunimovich`Private`dx <= QuantumWalks`L, 
              QuantumWalks`Billiards`Bunimovich`Private`dy <= 
              QuantumWalks`Billiards`Bunimovich`Private`R, 
              QuantumWalks`Billiards`Bunimovich`Private`dx <= 
              QuantumWalks`L + Round[
                 Sqrt[
                  Max[
                  0, QuantumWalks`Billiards`Bunimovich`Private`R^2 - 
                   QuantumWalks`Billiards`Bunimovich`Private`dy^2]]]]]]; 
         QuantumWalks`Billiards`Bunimovich`Private`coords = Select[
            Flatten[
             
             Table[{QuantumWalks`Billiards`Bunimovich`Private`x, 
               QuantumWalks`Billiards`Bunimovich`Private`y}, {
              QuantumWalks`Billiards`Bunimovich`Private`x, -QuantumWalks`L - 
               QuantumWalks`Billiards`Bunimovich`Private`R, QuantumWalks`L + 
               QuantumWalks`Billiards`Bunimovich`Private`R}, {
              QuantumWalks`Billiards`Bunimovich`Private`y, -
               QuantumWalks`Billiards`Bunimovich`Private`R, 
               QuantumWalks`Billiards`Bunimovich`Private`R}], 1], 
            Apply[QuantumWalks`Billiards`Bunimovich`Private`validRegionQ]]; 
         QuantumWalks`Billiards`Bunimovich`Private`stateToIndex = 
          AssociationThread[
           QuantumWalks`Billiards`Bunimovich`Private`coords -> Range[
              Length[QuantumWalks`Billiards`Bunimovich`Private`coords]]]; <|
          "Coords" -> QuantumWalks`Billiards`Bunimovich`Private`coords, 
           "Mapping" -> 
           QuantumWalks`Billiards`Bunimovich`Private`stateToIndex, 
           "Dimension" -> 
           Length[QuantumWalks`Billiards`Bunimovich`Private`coords], 
           "Params" -> <|
            "L" -> QuantumWalks`L, "R" -> 
             QuantumWalks`Billiards`Bunimovich`Private`R, "Symmetry" -> 
             "None"|>, "Type" -> "BunimovichFull"|>]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
