Cell[CellGroupData[{

Cell[TextData[StyleBox["BuildSymmetryIsometry[gridData,sector]", "Code"]], \
"Section",
 CellChangeTimes->{
  3.981045930235505*^9},ExpressionUUID->"85550258-29ff-4571-b0de-\
6760e58cd795"],

Cell["\<\
constructs the isometry matrix V for the specified symmetry sector of the \
given grid. This matrix projects the full Hilbert space into a specific \
symmetry subspace (e.g., parity sectors), which is essential for \
block-diagonalizing the Hamiltonian or evolution operators and reducing the \
computational cost of the simulation.\
\>", "Text",
 CellChangeTimes->{
  3.981045925499341*^9},ExpressionUUID->"0bed6223-bc5c-4e4e-bc37-\
7507a0b08eaa"],

Cell[TextData[{
 "For the grid provided via ",
 StyleBox["gridData", "Input",
  FontWeight->"Bold"],
 ", the function calculates transformations based on the format of the ",
 StyleBox["sector", "Input",
  FontWeight->"Bold"],
 " argument:"
}], "Text",ExpressionUUID->"a4fd1a50-550a-4315-8b56-7dae52af7ad5"],

Cell[TextData[{
 StyleBox["String",
  FontWeight->"Bold"],
 ": Predefined labels such as \"A1\", \"B2\", \"Even\", \"Odd\", or \
group-specific labels like \"C4v_A1\"."
}], "Item",ExpressionUUID->"fc372ccf-adce-49d7-a9c9-4da56e5442c2"],

Cell[TextData[{
 StyleBox["List {sx, sy}",
  FontWeight->"Bold"],
 ": Numerical spatial parities (e.g., {1, -1} for x-even, y-odd) to define a \
sector in C2v symmetry."
}], "Item",ExpressionUUID->"20dd0b5e-57de-43a4-88fa-bd84a6bc699d"],

Cell[TextData[{
 StyleBox["Integer sy",
  FontWeight->"Bold"],
 ": A single parity value (1 or -1) to define a sector for bilateral symmetry \
along the y-axis."
}], "Item",ExpressionUUID->"2c153391-7d4b-40e7-aeb5-093721e95f3a"],

Cell[TextData[{
 StyleBox["Association",
  FontWeight->"Bold"],
 " ",
 ButtonBox["chars",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 ": A dictionary mapping group operations to characters for C4v symmetry (8 \
isometries)."
}], "Item",ExpressionUUID->"eecb5c67-9aec-4751-a4e3-a5a9ce6ae421"],

Cell[TextData[{
 "The function uses the grid definition from the ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " and returns a SparseArray representing the isometry V. The resulting \
matrix has dimensions (4 * Dimension) \[Times] ReducedDimension."
}], "Text",ExpressionUUID->"6d827b6a-b166-4ae9-809d-f7abc0d78465"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",ExpressionUUID->"bd35ed5d-1546-4df4-9edc-a788cbdb9d96"],

Cell["\<\
Construct the isometry for the totally symmetric sector (A1) of a Bunimovich \
stadium:\
\>", "Text",ExpressionUUID->"b63cf15b-e146-46a1-a293-cf1a5c7d3897"],

Cell[BoxData[
 RowBox[{
  RowBox[{"grid", "=", 
   RowBox[{"GenerateFullStadiumBasis", "[", 
    RowBox[{"22", ",", "20"}], "]"}]}], ";", 
  RowBox[{"isometryA1", "=", 
   RowBox[{"BuildSymmetryIsometry", "[", 
    RowBox[{"grid", ",", "\"\<A1\>\""}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981046052317215*^9, 3.981046053971574*^9}, {
  3.981046219844987*^9, 3.981046247139399*^9}},
 CellLabel->"In[89]:=",ExpressionUUID->"3abe72fa-7a76-4a5d-9ab6-6c8598b8da62"],

Cell["The grid in question:", "Text",
 CellChangeTimes->{{3.981046368362747*^9, 
  3.981046371907119*^9}},ExpressionUUID->"b6e4edfc-4c24-4776-9703-\
2ec8c2bf569c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"grid", "[", "\"\<Coords\>\"", "]"}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", "Automatic"}], ",", " ", "\n", "  ", 
   RowBox[{"PlotStyle", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PointSize", "[", "0.01", "]"}], ",", " ", "Blue"}], "}"}]}], ",",
    " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{"ImageSize", "->", "Large"}], ",", 
   RowBox[{"LabelStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", 
      RowBox[{"FontSize", "\[Rule]", 
       RowBox[{"Scaled", "[", ".04", "]"}]}]}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981046339699868*^9, 3.981046345790145*^9}, {
  3.981046544841359*^9, 3.9810466202787952`*^9}},
 CellLabel->
  "In[107]:=",ExpressionUUID->"30142a5f-7397-4d8a-8d9c-f19bbfcb8e92"],

