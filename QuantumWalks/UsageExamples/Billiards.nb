       Rational[-1, 2] Rational[3, 2]^Rational[1, 2], Rational[-1, 2] 
       2^Rational[-1, 2], Rational[1, 2] 
       Rational[3, 2]^Rational[1, 2]}}]]]]], "Output",
 CellChangeTimes->{
  3.9810366110095243`*^9, {3.981036672162663*^9, 3.98103667735457*^9}},
 CellLabel->
  "Out[102]//MatrixForm=",ExpressionUUID->"c26481d1-45fb-407d-a8ba-\
57b2c468a879"]
}, Closed]],

