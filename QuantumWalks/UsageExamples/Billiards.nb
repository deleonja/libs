70b0b8d4d2f4"],

Cell[TextData[{
 "The Coin ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "C", ")"}], TraditionalForm]],ExpressionUUID->
  "e6e85a8a-d4c7-4595-88c1-083dca4d14c6"],
 ": Rotates the internal spin state."
}], "Item",
 CellChangeTimes->{{3.9781010586201363`*^9, 3.97810106768517*^9}, {
  3.978101099142581*^9, 
  3.978101109915923*^9}},ExpressionUUID->"87c45e5e-66b9-4d9c-98c4-\
6d39b944575a"],

Cell[TextData[{
 "The Shift operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["S", "x"], ",", " ", 
     SubscriptBox["S", "y"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "0328dfdc-6c36-4abb-b3b5-6c1199d44f8e"],
 ": Move the particle Left/Right and Up/Down based on its spin. "
}], "Item",
 CellChangeTimes->{{3.9781010586201363`*^9, 3.978101078455714*^9}, {
  3.978101112990018*^9, 3.978101134227997*^9}, {3.978123216197413*^9, 
