Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"3.", " ", "Estado", " ", "Inicial", " ", 
    RowBox[{"(", 
     RowBox[{
     "Paquete", " ", "Gaussiano", " ", "centrado", " ", "espacialmente"}], 
     ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"SigmaGauss", " ", "=", " ", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"CentroGrid", " ", "=", " ", 
     RowBox[{"Round", "[", 
      RowBox[{"Mean", "[", "Coords", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Base", " ", "espacial", " ", "Gaussiana", " ", "normalizada"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"AmplitudesEspaciales", " ", "=", " ", 
     RowBox[{"Chop", "@", 
      RowBox[{"Normalize", "[", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", 
                 RowBox[{"CentroGrid", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "^", "2"}], " ", "+",
               " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], " ", "-", " ", 
                 RowBox[{"CentroGrid", "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "^", "2"}]}], 
             ")"}]}], " ", "/", " ", 
           RowBox[{"(", 
            RowBox[{"2", " ", "*", " ", 
             RowBox[{"SigmaGauss", "^", "2"}]}], ")"}]}], "]"}], " ", "&"}], 
        " ", "/@", " ", "Coords"}], "\n", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Moneda", " ", "inicial", " ", "sim\[EAcute]trica", " ", 
     RowBox[{"(", 
      RowBox[{
      "Arriba", ",", " ", "Abajo", ",", " ", "Derecha", ",", " ", 
       "Izquierda"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"EstadoMoneda", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", "1"}], "}"}], " ",
       "/", " ", "2."}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Producto", " ", "tensorial", " ", "O", 
       RowBox[{"(", "N", ")"}]}], ":", " ", 
      RowBox[{"|", 
