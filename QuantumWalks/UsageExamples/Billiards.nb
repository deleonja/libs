Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateEllipseBasis[A,B]", "Code"]], "Section",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"9a3b7161-d94d-4e75-a2ac-f0c9d9ffd297"],

Cell["\<\
The function generates the coordinate basis for an elliptical billiard \
defined by (x/A)^2 + (y/B)^2 \[LessEqual] 1. If A = B, the function generates \
a circular billiard grid.\
\>", "Text",ExpressionUUID->"9af95a31-e499-46dd-8e52-cd7ef753300f"],

Cell[TextData[{
 "For the elliptical billiard with semi-axes ",
 StyleBox["A",
  FontWeight->"Bold"],
 " and ",
 StyleBox["B",
  FontWeight->"Bold"],
 ", it returns an ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object with the following keys:"
}], "Text",ExpressionUUID->"916b066c-6591-4d83-964e-1a38c37a6d03"],

Cell[TextData[{
 StyleBox["\"Coords\"",
  FontWeight->"Bold"],
 ": A flat list of coordinates {x, y} within the elliptical region."
}], "Item",ExpressionUUID->"c1de36ce-0852-4249-90a2-872fed22f067"],

Cell[TextData[{
 StyleBox["\"Mapping\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " for fast coordinate lookups."
}], "Item",ExpressionUUID->"9fbcd7d0-f35d-4edb-a390-f0d4cf98e55d"],

Cell[TextData[{
 StyleBox["\"Params\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing: <|\"A\" \[Rule] A, \"B\" \[Rule] B|>."
}], "Item",ExpressionUUID->"1cc57724-8ee6-4953-9b28-b11a5ca29c87"],

Cell[TextData[{
 StyleBox["\"Type\"",
  FontWeight->"Bold"],
 ": Returns \"Ellipse\" or \"Circle\" if the axes are equal."
}], "Item",ExpressionUUID->"6698912d-9a21-4474-a9f9-49266217d2bb"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"aced6af4-4c20-42cc-8947-2582079164bd"],

Cell[TextData[{
 "Elliptical grid with horizontal semi-axis ",
 StyleBox["A=30",
  FontWeight->"Bold"],
 " and vertical semi-axis ",
 StyleBox["B=15",
  FontWeight->"Bold"],
 ":"
}], "Text",ExpressionUUID->"e72e6ccb-fd81-41a3-90a1-75d363d09548"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EllipseData", "=", 
   RowBox[{"GenerateEllipseBasis", "[", 
    RowBox[{"30", ",", "15"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"0d86bc0a-5ade-4e81-819e-9b07cba7bcbb"],

Cell["Visualize the elliptical grid:", "Text",ExpressionUUID->"b77ce220-5739-4b86-a11d-4c5423694a0b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"EllipseData", "[", "\"\<Coords\>\"", "]"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"PointSize", "[", "0.01`", "]"}], "]"}]}], ",", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
   RowBox[{"FrameStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "20"}], "]"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]], "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"41321c47-8e6f-4e53-9d5c-68435933d170"],

