   " ", 
   RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]], "Input",
 CellChangeTimes->{3.981033210130189*^9},
 CellLabel->"In[69]:=",ExpressionUUID->"cec80664-ec4a-43a2-8602-4adeaf0eae34"],

