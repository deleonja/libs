Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateFullStadiumBasis[l,R]", "Code"]], "Section",
 CellChangeTimes->{{3.981033060432534*^9, 3.9810330614575777`*^9}, 
   3.9810386311734447`*^9, {3.9810435885010223`*^9, 3.98104358880475*^9}, 
   3.981043669940371*^9},ExpressionUUID->"4d574b41-31c1-4f66-99fb-\
e7d4e773a1e3"],

Cell["\<\
generates the coordinate basis and mapping for the full (non-desymmetrized) \
Bunimovich stadium. It iterates over a bounding box defined by the \
semi-length L and radius R , selecting integer points that fall within either \
the central rectangular region or the semicircular ends.

For the full Bunimovich stadium with semi-length L and radius R, it returns \
an Association object with the following keys:\
\>", "Text",
 CellChangeTimes->{{3.981033101872563*^9, 3.981033140385744*^9}, 
   3.9810373180839376`*^9},ExpressionUUID->"4cd4e13c-6341-4205-a2dd-\
e8d81090b57b"],

Cell["\<\
\"Coords\" : A flat list with all valid spatial coordinates {x, y} that form \
the basis of the position Hilbert subspace . \
\>", "Item",
 CellChangeTimes->{{3.981033142710685*^9, 
  3.981033153543532*^9}},ExpressionUUID->"ea4fb6e1-0a80-4efa-9e7d-\
391cb0177474"],

Cell["\<\
\"Mapping\" : An Association object that acts as a dictionary . It allows \
entering a coordinate (e . g ., {0, 0}) and obtaining its corresponding \
matrix index in O (1) time . \
\>", "Item",
 CellChangeTimes->{{3.981033142710685*^9, 
  3.98103315669613*^9}},ExpressionUUID->"83b81b95-efe9-46c2-b58c-\
6d13a88757c5"],

Cell["\<\
\"Dimension\" : An integer indicating the total dimension of the spatial \
basis . \
\>", "Item",
 CellChangeTimes->{{3.981033142710685*^9, 
  3.9810331592025223`*^9}},ExpressionUUID->"053cb152-ed6a-4233-b3af-\
9ef53f606a82"],

Cell["\<\
\"Params\" : An Association containing the original input parameters, saved \
as <|\"L\" -> L, \"R\" -> R, \"Symmetry\" -> \"None\"|> .\
\>", "Item",
 CellChangeTimes->{{3.981033142710685*^9, 
  3.9810331608239927`*^9}},ExpressionUUID->"1a97e7bb-ec74-4e09-9592-\
79a9225cbb1b"],

Cell["\<\
\"Type\" : The label \"BunimovichFull\" to identify the generated geometry .\
\>", "Item",
 CellChangeTimes->{{3.981033142710685*^9, 
  3.981033161977501*^9}},ExpressionUUID->"58dc111d-256b-4db0-9fc8-\
850b8465aa4f"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 CellChangeTimes->{{3.9810331711740923`*^9, 
  3.981033172496768*^9}},ExpressionUUID->"20bed74d-9c1e-4b8c-b792-\
30f42d81e2b1"],

Cell["\<\
Coordinate basis and mapping for a full Bunimovich stadium of semi-length \
L=10 and radius R=15:\
\>", "Text",
 CellChangeTimes->{{3.981033183493017*^9, 
  3.981033184924559*^9}},ExpressionUUID->"5487e241-ab76-43d6-b47a-\
ff10526c5eaf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"FullStadiumData", "=", 
   RowBox[{"GenerateFullStadiumBasis", "[", 
    RowBox[{"10", ",", "15"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981033189156498*^9, 3.9810331891565723`*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"acbfe67f-5f43-4e24-83b6-75f3408709a5"],

Cell[TextData[{
 "The grid of ",
 StyleBox["FullStadiumData", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{
  3.981033200383937*^9},ExpressionUUID->"ee5da49d-15f7-47c1-a51b-\
585107ac88b4"],

