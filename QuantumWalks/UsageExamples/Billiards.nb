Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"FullStadiumData", "[", "\"\<Coords\>\"", "]"}], ",", " ", "\n", 
   " ", 
   RowBox[{"AspectRatio", " ", "->", " ", "Automatic"}], ",", " ", "\n", " ", 
   
   RowBox[{"PlotStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{"PointSize", "[", "0.015", "]"}], "]"}]}], ",", " ", "\n", " ", 
