Cell[CellGroupData[{

Cell["Routines\[CloseCurlyQuote] details and usage examples", "Chapter",
 CellChangeTimes->{{3.981031302893216*^9, 
  3.981031338420267*^9}},ExpressionUUID->"07c37951-4e50-4d5f-9726-\
72880d9f8246"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["BuildShiftOperators[gridData,opts]", "Code"]], \
"Section",
 CellChangeTimes->{3.981030134901288*^9, 3.981033350193591*^9, 
  3.981033494535183*^9},ExpressionUUID->"0199a677-1413-473a-8b1d-\
c41eb6c6839c"],

Cell["\<\
constructs the shift operators of a DTQW for a given grid geometry. These \
operators move the quantum walker between adjacent nodes while implementing \
unitary bounce-back boundary conditions\[LongDash]if the walker hits the edge \
of the billiard, it reflects into the opposite internal state to preserve the \
total probability.\
\>", "Text",
 CellChangeTimes->{{3.981033400719678*^9, 3.981033441990327*^9}, {
   3.981033533331706*^9, 3.98103353541919*^9}, {3.981033879664484*^9, 
   3.98103387979244*^9}, 
   3.981037239229766*^9},ExpressionUUID->"cc2219f9-40db-4394-aa32-\
adddf225791a"],

Cell[TextData[{
 "For a grid provided via ",
 StyleBox["gridData", "Input"],
 ", it returns the operators based on the chosen ",
 StyleBox["CoinDimension", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.981033446685297*^9, 
  3.98103345141505*^9}},ExpressionUUID->"dde3ebfd-a679-45ed-8f62-\
4b061ad7b748"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["CoinDimension -> 2", "Input"],
 " (Default): Returns a list of two matrices {Sx, Sy} for a split-step \
quantum walk."
}], "Item",
 CellChangeTimes->{{3.981033454225666*^9, 3.981033466791534*^9}, {
  3.981033553065654*^9, 
  3.981033553574306*^9}},ExpressionUUID->"ebe67134-09b0-4dc5-b7ca-\
73688e881630"],

Cell["Sx: Horizontal conditional shift.", "Subitem",
 CellChangeTimes->{{3.981033573457932*^9, 
  3.98103357591145*^9}},ExpressionUUID->"f5e5679c-0018-4523-a623-\
2b32423e779f"],

Cell["Sy: Vertical conditional shift.", "Subitem",
 CellChangeTimes->{{3.981033573457932*^9, 
  3.9810335753717737`*^9}},ExpressionUUID->"23848009-21ac-4af4-9a2f-\
d98729f4fe38"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["CoinDimension -> 4", "Input"],
 ": Returns a single global matrix S for a 4-coin-state DTQW."
}], "Item",
 CellChangeTimes->{{3.981033454225666*^9, 3.9810334702732973`*^9}, {
  3.981033965440164*^9, 
  3.981033972148344*^9}},ExpressionUUID->"ae88a798-21ed-426f-86f2-\
c23335a8158c"],

Cell["\<\
Internal states are encoded as: 1:Up (+y), 2:Down (\[Minus]y), 3:Right (+x), \
4:Left (\[Minus]x).\
\>", "Subitem",
 CellChangeTimes->{{3.981033454225666*^9, 
  3.9810334773549643`*^9}},ExpressionUUID->"0e26fa36-fac7-4cf7-a8a1-\
7adf2ea85e2a"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Note 1",
  FontWeight->"Bold"],
 ": All operators are returned as ",
 StyleBox["SparseArray", "Input"],
 " objects to ensure high performance in large-scale simulations."
}], "Text",
 CellChangeTimes->{
  3.981033480095854*^9, {3.981033607979076*^9, 
   3.981033609814698*^9}},ExpressionUUID->"7d729a70-0ee4-4c62-a79b-\
3959a9182a5e"],

Cell[TextData[{
 StyleBox["Note 2:",
  FontWeight->"Bold"],
 " ",
 StyleBox["gridData", "Input"],
 " may be any other geometry with the same structure as that the output of \
functions ",
 StyleBox["Generate...Basis", "Input"],
 "."
}], "Text",
 CellChangeTimes->{{3.981033613110375*^9, 
  3.9810337211337233`*^9}},ExpressionUUID->"dfcd4626-1508-43db-afa9-\
d0bb2ac92a5d"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 CellChangeTimes->{{3.981033388575048*^9, 
  3.981033392587722*^9}},ExpressionUUID->"aa6bb5a5-be3a-4c6a-aa03-\
512890cc71b3"],

Cell["\<\
Constructing operators for a split-step walk on a Bunimovich stadium \
(L=10,R=15):\
\>", "Text",
 CellChangeTimes->{{3.981033730051453*^9, 
  3.981033731557543*^9}},ExpressionUUID->"ef1c6264-202d-4798-84ea-\
572bf8f2a7a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Generate", " ", "the", " ", "grid"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"BunimovichData", "=", 
     RowBox[{"GenerateBunimovichBasis", "[", 
      RowBox[{"10", ",", "15"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Build", " ", "2"}], "-", 
     RowBox[{"state", " ", "split"}], "-", 
     RowBox[{"step", " ", "operators", " ", 
      RowBox[{"(", "default", ")"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Sx", ",", "Sy"}], "}"}], "=", 
     RowBox[{"BuildShiftOperators", "[", "BunimovichData", "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.981033753004681*^9, 3.9810337577779217`*^9}},
 CellLabel->"In[81]:=",ExpressionUUID->"70c32915-1e92-41d6-a4db-9c5906c03262"],

Cell["The horizontal shift operator Sx structure:", "Text",
 CellChangeTimes->{{3.9810337347727737`*^9, 
  3.98103373579767*^9}},ExpressionUUID->"6bba8d4f-c5f9-4594-b04d-\
bddef3bc9537"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Check", " ", "the", " ", "dimensions", " ", 
    RowBox[{"(", 
     RowBox[{"2", " ", "states", " ", "per", " ", "spatial", " ", "node"}], 
     ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"Dimensions", "[", "Sx", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Verify", " ", "that", " ", "the", " ", "operator", " ", "is", " ", 
     "Unitary"}], " ", "*)"}], "\n", 
   RowBox[{"UnitaryMatrixQ", "[", "Sx", "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.981033769769744*^9, {3.9810338333022833`*^9, 
   3.9810338378054647`*^9}},ExpressionUUID->"d37bb712-7297-43a4-b67f-\
ac085e92c382"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"706", ",", "706"}], "}"}]], "Output",
 CellChangeTimes->{3.9810337713142633`*^9, 3.9810338028388033`*^9},
 CellLabel->"Out[83]=",ExpressionUUID->"8f840354-8b65-4456-8158-aec3508d3fe6"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.9810337713142633`*^9, 3.981033802840006*^9},
 CellLabel->"Out[84]=",ExpressionUUID->"9a392c55-96cc-4309-bd21-2ae80daec8ef"]
}, Open  ]],

Cell["Constructing a single global operator for a 4-state walk:", "Text",
 CellChangeTimes->{{3.98103374010349*^9, 
  3.981033741363065*^9}},ExpressionUUID->"e89ceca4-fd34-4b19-a991-\
0a372a80efd3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Build", " ", "4"}], "-", 
    RowBox[{"state", " ", "Grover", " ", "shift", " ", "operator"}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"SGlobal", " ", "=", " ", 
     RowBox[{"BuildShiftOperators", "[", 
      RowBox[{"BunimovichData", ",", " ", 
       RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Check", " ", "the", " ", "dimensions", " ", 
     RowBox[{"(", 
      RowBox[{"4", " ", "states", " ", "per", " ", "spatial", " ", "node"}], 
      ")"}]}], " ", "*)"}], "\n", 
   RowBox[{"Dimensions", "[", "SGlobal", "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.981033780694759*^9, {3.981033828730289*^9, 
   3.981033829010428*^9}},ExpressionUUID->"b57ef989-76a0-49b8-aabc-\
4f8fd47d6aef"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1412", ",", "1412"}], "}"}]], "Output",
 CellChangeTimes->{3.981033805495566*^9},
 CellLabel->"Out[86]=",ExpressionUUID->"550cc3df-5e85-4fa4-92d9-3918d517d655"]
}, Open  ]],

Cell["\<\
Obtain the total number of non-zero entries to verify sparsity:\
\>", "Text",
 CellChangeTimes->{{3.981033747147787*^9, 
  3.981033748423394*^9}},ExpressionUUID->"0b3d0fba-32c3-4b7e-9304-\
8728bc28bd6b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ArrayRules", "[", "SGlobal", "]"}], " ", "//", " ", 
  "Length"}]], "Input",
 CellChangeTimes->{{3.981033786573389*^9, 
  3.9810338253598537`*^9}},ExpressionUUID->"677faa1c-f560-49cb-938a-\
c17b557b12ea"],

Cell[BoxData["1413"], "Output",
 CellChangeTimes->{{3.981033788776245*^9, 3.981033816130909*^9}},
 CellLabel->"Out[88]=",ExpressionUUID->"416f793d-b519-49c0-b7a7-29aac4cb353d"]
}, Open  ]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["GeneralizedGroverCoin[\[Theta]]", "Code"]], "Section",
 CellChangeTimes->{
  3.981030139550342*^9, {3.9810360359105263`*^9, 3.981036039537189*^9}, {
   3.981036517184963*^9, 
   3.9810365180036287`*^9}},ExpressionUUID->"28727973-2a06-498a-a672-\
d672005dd919"],

Cell[TextData[{
 "yields the 4\[Times]4 anisotropic Grover coin matrix \
2*\[Divides]s(\[Theta])\:27e9\:27e8s(\[Theta])\[Divides] - ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "4"], TraditionalForm]],ExpressionUUID->
  "be3e75d1-31d7-4af7-80ba-562e463461a0"],
 ", with \[Divides]s(\[Theta])\:27e9= ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", 
    SqrtBox["2"]}], TraditionalForm]],ExpressionUUID->
  "880621c8-7db5-42c5-b303-2a602dda611c"],
 "{cos(\[Theta]),cos(\[Theta]),sin(\[Theta]),sin(\[Theta])}."
}], "Text",
 CellChangeTimes->{{3.981036098360095*^9, 3.981036100725362*^9}, {
  3.98103621697027*^9, 3.981036290907542*^9}, {3.9810372610449667`*^9, 
  3.98103726122049*^9}},ExpressionUUID->"67dadb51-9290-49bb-866e-\
5b63e13db50d"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 CellChangeTimes->{{3.981036076594344*^9, 
  3.9810360784173613`*^9}},ExpressionUUID->"15073fc8-2f1c-45b5-b504-\
95b75eb04b72"],

Cell["Generating a standard Grover coin (\[Theta]=\[Pi]/4):", "Text",
 CellChangeTimes->{{3.981036128477993*^9, 
  3.981036129964113*^9}},ExpressionUUID->"6f48e6a3-2900-4da1-b16b-\
3f3efe5d3d4d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"GroverCoin", "=", 
   RowBox[{"GeneralizedGroverCoin", "[", 
    RowBox[{"Pi", "/", "4"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981036137938365*^9, 3.981036143588881*^9}, {
  3.981036753316206*^9, 3.981036769041506*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"95a40100-3255-45ab-8626-1b58c95f9ea0"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"-", 
       FractionBox["1", "2"]}], 
      FractionBox["1", "2"], 
      FractionBox["1", "2"], 
      FractionBox["1", "2"]},
     {
      FractionBox["1", "2"], 
      RowBox[{"-", 
       FractionBox["1", "2"]}], 
      FractionBox["1", "2"], 
      FractionBox["1", "2"]},
     {
      FractionBox["1", "2"], 
      FractionBox["1", "2"], 
      RowBox[{"-", 
       FractionBox["1", "2"]}], 
      FractionBox["1", "2"]},
     {
      FractionBox["1", "2"], 
      FractionBox["1", "2"], 
      FractionBox["1", "2"], 
      RowBox[{"-", 
       FractionBox["1", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{
  3.9810361504629717`*^9, {3.981036757382102*^9, 3.981036770435161*^9}},
 CellLabel->
  "Out[108]//MatrixForm=",ExpressionUUID->"10733290-1b6a-43f7-83fa-\
32b9d6106776"]
}, Closed]],

Cell[TextData[{
 "Verify ",
 StyleBox["GroverCoin", "Input"],
 " is unitary:"
}], "Text",
 CellChangeTimes->{{3.981036159128325*^9, 
  3.981036177740296*^9}},ExpressionUUID->"aad06ac6-1805-4762-8583-\
a44b141b7efd"],

