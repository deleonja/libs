Cell[CellGroupData[{

Cell[TextData[StyleBox["GenerateFullSinaiBasis[L,R]", "Code"]], "Section",
 CellChangeTimes->{{3.981044876735297*^9, 3.981044877935225*^9}},
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"a0b01a35-175c-4d06-b197-dbddf5350c3e"],

Cell["\<\
generates the coordinate basis for the full Sinai billiard. The geometry \
consists of a square of side 2L (centered at the origin) with a circular \
obstacle of radius R removed from the center[cite: 47, 49, 54, 55].\
\>", "Text",
 CellChangeTimes->{
  3.981045363828375*^9},ExpressionUUID->"78055ecf-7fba-4471-9e0f-\
f727b57e95fc"],

Cell[TextData[{
 "For the full Sinai billiard, it returns an ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " object with the following keys[cite: 49, 59]:"
}], "Text",ExpressionUUID->"c890472f-b194-461b-a2f7-fd059147841a"],

Cell[TextData[{
 StyleBox["\"Coords\"",
  FontWeight->"Bold"],
 ": A list of all coordinates {x, y} within the square [-L, L] such that x^2 \
+ y^2 \[GreaterEqual] R^2[cite: 56, 57, 58]."
}], "Item",ExpressionUUID->"183a6e1d-fc1d-4528-a23f-2711165d468e"],

Cell[TextData[{
 StyleBox["\"Mapping\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " for fast coordinate mapping in the full Hilbert space[cite: 58, 59]."
}], "Item",ExpressionUUID->"cc6583d7-bab2-4dff-97e1-88a007054e90"],

Cell[TextData[{
 StyleBox["\"Params\"",
  FontWeight->"Bold"],
 ": An ",
 ButtonBox["Association",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Association"],
 " containing: <|\"L\" \[Rule] L, \"R\" \[Rule] R, \"Symmetry\" \[Rule] \
\"None\"|>[cite: 59]."
}], "Item",ExpressionUUID->"07c69e20-7365-4ad5-a4d3-9f2a90d040f8"],

Cell[CellGroupData[{

Cell["Usage example", "Subsection",
 FontColor->RGBColor[
  0.85, 0.39, 0.14],ExpressionUUID->"a9882b94-4bbd-4068-85b8-c5a73fcf9f22"],

Cell[TextData[{
 "Full Sinai billiard grid with ",
 StyleBox["L=15",
  FontWeight->"Bold"],
 " and ",
 StyleBox["R=8",
  FontWeight->"Bold"],
 ":"
}], "Text",ExpressionUUID->"19bb0296-bbf9-4b37-bd97-cc4bcdc29d45"],

Cell[BoxData[
 RowBox[{
  RowBox[{"FullSinaiData", "=", 
   RowBox[{"GenerateFullSinaiBasis", "[", 
    RowBox[{"15", ",", "8"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"ebfdc543-598d-4f3c-a5f7-291f8d5f78f5"],

Cell["Visualize the full Sinai billiard grid:", "Text",ExpressionUUID->"e73b861a-1b7d-4ce1-8642-1c5a5eaf27f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
