Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Inicializar", " ", "la", " ", "Geometr\[IAcute]a", " ", 
    RowBox[{"(", 
     RowBox[{"Estadio", " ", "de", " ", "Bunimovich", " ", "a", " ", 
      RowBox[{"1", "/", "4"}]}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"R", " ", "=", " ", "12"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"l", " ", "=", " ", "12"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"GridData", " ", "=", " ", 
     RowBox[{"GenerateBunimovichBasis", "[", 
      RowBox[{"l", ",", " ", "R"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Coords", " ", "=", " ", 
     RowBox[{"GridData", "[", "\"\<Coords\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TotalDim", " ", "=", " ", 
     RowBox[{"GridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Construcci\[OAcute]n", " ", "de", " ", "Operadores", " ", 
     "Unitarios", " ", 
     RowBox[{"(", 
      RowBox[{"Espacio", " ", "Completo", " ", "de", " ", "Hilbert"}], 
      ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"S", " ", "=", " ", 
     RowBox[{"BuildShiftOperators", "[", 
      RowBox[{"GridData", ",", " ", 
       RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"CoinGlobal", " ", "=", " ", "\[IndentingNewLine]", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"TotalDim", ",", " ", "SparseArray"}], "]"}], ",", " ", 
       RowBox[{"SparseArray", "[", 
        RowBox[{"GeneralizedGroverCoin", "[", 
         RowBox[{"Pi", "/", "4."}], "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Operador", " ", "de", " ", "Paso", " ", "Temporal"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"U", " ", "=", " ", 
     RowBox[{"S", " ", ".", " ", "CoinGlobal"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{
