Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ListDensityPlot", "[", 
    RowBox[{
     RowBox[{"StateToPlotData", "[", 
      RowBox[{
       RowBox[{"evecs", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"billiardData", "[", "\"\<Coords\>\"", "]"}]}], "]"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<SunsetColors\>\""}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
     RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
     RowBox[{"InterpolationOrder", "->", "0"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Recorte", " ", "exacto", " ", "usando", " ", "la", " ", 
       "geometr\[CapitalATilde]\[DiscretionaryHyphen]a", " ", "del", " ", 
       "estadio"}], "*)"}], 
     RowBox[{"RegionFunction", "->", 
      RowBox[{"Function", "[", 
