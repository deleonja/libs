Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "1.", " ", "Analytic", " ", "evaluation", " ", "of", " ", "the", " ", 
    "coin"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"AnalyticBlockCoin", " ", "=", " ", 
     RowBox[{"BlockDiagonalCoin", "[", "\[Phi]", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Analytic Block-Diagonal Coin: \>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{"MatrixForm", "[", "AnalyticBlockCoin", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Test", " ", "with", " ", "a", " ", "specific", " ", 
     "physical", " ", "parameter", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"e", ".", "g", "."}], ",", " ", 
       RowBox[{"phi", " ", "=", " ", 
        RowBox[{"\[Pi]", "/", "3"}]}]}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"TestCoin", " ", "=", " ", 
     RowBox[{"BlockDiagonalCoin", "[", 
      RowBox[{"Pi", "/", "3"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nEvaluated Coin (\[Phi] = \[Pi]/3): \>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{"MatrixForm", "[", "TestCoin", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"3.", " ", "Physical", " ", "Validation", " ", 
     RowBox[{"(", 
      RowBox[{"Unitarity", " ", "check"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Note", ":", " ", 
      RowBox[{"Unlike", " ", "Grover"}]}], ",", " ", 
     RowBox[{
      RowBox[{
      "this", " ", "coin", " ", "is", " ", "NOT", " ", "generally", " ", 
       "Hermitian", " ", "due", " ", "to", " ", "the", " ", "imaginary", " ", 
       "off"}], "-", "diagonals"}], ",", " ", "\n", "   ", 
     RowBox[{
     "but", " ", "it", " ", "MUST", " ", "strictly", " ", "be", " ", 
      "Unitary", " ", "to", " ", "preserve", " ", "probability", " ", "in", " ",
       "the", " ", 
      RowBox[{"DTQW", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"IsUnitary", " ", "=", " ", 
     RowBox[{"UnitaryMatrixQ", "[", 
      RowBox[{"Normal", "@", 
       RowBox[{"Simplify", "[", 
        RowBox[{"AnalyticBlockCoin", ",", " ", 
         RowBox[{"Assumptions", " ", "->", " ", 
          RowBox[{"Element", "[", 
           RowBox[{"\[Phi]", ",", " ", "Reals"}], "]"}]}]}], "]"}]}], "]"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nIs the operator strictly unitary for real \[Phi]? \>\"", 
      ",", " ", "IsUnitary"}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "4.", " ", "Creating", " ", "the", " ", "Global", " ", "Coin", " ", 
     "Operator", " ", "for", " ", "a", " ", "2", "D", " ", "Grid"}], " ", 
    "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Assuming", " ", "you", " ", "have", " ", "a", " ", "grid", " ", "of", " ",
      "dimension", " ", "N", " ", "generated", " ", "by", " ", "your", " ", 
     "Billiards", " ", "package"}], " ", "*)"}], "\n", 
   RowBox[{"(*", "\n", "  ", 
    RowBox[{
     RowBox[{"GridDimension", " ", "=", " ", "250"}], ";", "\n", "  ", 
     RowBox[{"GlobalBlockCoin", " ", "=", " ", 
      RowBox[{"Coin", "[", 
       RowBox[{"TestCoin", ",", " ", "GridDimension"}], "]"}]}], ";"}], "\n", 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.980880841682869*^9, 3.980880858210226*^9}, {
  3.9808809017527637`*^9, 3.980880920843276*^9}},
